<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:sys="clr-namespace:System;assembly=System.Runtime"
             xmlns:vm="using:HelixExplorer.ViewModels"
             xmlns:models="using:HelixExplorer.Core.Models"
             xmlns:controls="using:HelixExplorer.Controls"
             x:Class="HelixExplorer.Views.PaneView"
             x:DataType="vm:PaneViewModel"
             Focusable="True"
             KeyDown="OnPaneKeyDown"
             DragDrop.AllowDrop="True"
             DragDrop.Drop="OnDrop"
             DragDrop.DragOver="OnDragOver">

    <UserControl.Styles>
        <Style Selector="ListBoxItem:selected /template/ ContentPresenter">
            <Setter Property="Background" Value="{DynamicResource HelixSelectionFillBrush}" />
        </Style>
        <Style Selector="UserControl.inactive ListBoxItem:selected /template/ ContentPresenter">
            <Setter Property="Background" Value="{DynamicResource HelixSelectionInactiveFillBrush}" />
        </Style>
        <Style Selector="DataGrid#DetailsGrid DataGridRow:selected /template/ Rectangle#BackgroundRectangle">
            <Setter Property="Fill" Value="{DynamicResource HelixSelectionFillBrush}" />
            <Setter Property="Opacity" Value="1" />
        </Style>
        <Style Selector="DataGrid#DetailsGrid DataGridRow:selected:pointerover /template/ Rectangle#BackgroundRectangle">
            <Setter Property="Fill" Value="{DynamicResource HelixSelectionFillBrush}" />
            <Setter Property="Opacity" Value="1" />
        </Style>
        <Style Selector="DataGrid#DetailsGrid DataGridRow:selected:focus /template/ Rectangle#BackgroundRectangle">
            <Setter Property="Fill" Value="{DynamicResource HelixSelectionFillBrush}" />
            <Setter Property="Opacity" Value="1" />
        </Style>
        <Style Selector="DataGrid#DetailsGrid DataGridRow:selected:pointerover:focus /template/ Rectangle#BackgroundRectangle">
            <Setter Property="Fill" Value="{DynamicResource HelixSelectionFillBrush}" />
            <Setter Property="Opacity" Value="1" />
        </Style>
        <Style Selector="UserControl.inactive DataGrid#DetailsGrid DataGridRow:selected /template/ Rectangle#BackgroundRectangle">
            <Setter Property="Fill" Value="{DynamicResource HelixSelectionInactiveFillBrush}" />
            <Setter Property="Opacity" Value="1" />
        </Style>
        <Style Selector="UserControl.inactive DataGrid#DetailsGrid DataGridRow:selected:pointerover /template/ Rectangle#BackgroundRectangle">
            <Setter Property="Fill" Value="{DynamicResource HelixSelectionInactiveFillBrush}" />
            <Setter Property="Opacity" Value="1" />
        </Style>
        <Style Selector="UserControl.inactive DataGrid#DetailsGrid DataGridRow:selected:focus /template/ Rectangle#BackgroundRectangle">
            <Setter Property="Fill" Value="{DynamicResource HelixSelectionInactiveFillBrush}" />
            <Setter Property="Opacity" Value="1" />
        </Style>
        <Style Selector="UserControl.inactive DataGrid#DetailsGrid DataGridRow:selected:pointerover:focus /template/ Rectangle#BackgroundRectangle">
            <Setter Property="Fill" Value="{DynamicResource HelixSelectionInactiveFillBrush}" />
            <Setter Property="Opacity" Value="1" />
        </Style>
        <Style Selector="UserControl.inactive Border.selectionActive">
            <Setter Property="Opacity" Value="0" />
        </Style>
        <Style Selector="UserControl:not(.inactive) Border.selectionInactive">
            <Setter Property="Opacity" Value="0" />
        </Style>
    </UserControl.Styles>

    <UserControl.Resources>
        <ContextMenu x:Key="EntryContextMenu"
                     x:CompileBindings="False"
                     Opening="OnEntryContextMenuOpening">
            <StackPanel Orientation="Horizontal" Spacing="2" Margin="4,2">
                <Button Classes="toolButton" ToolTip.Tip="Cut" Command="{Binding CutCommand}">
                    <PathIcon Data="{DynamicResource HelixIconCutGeometry}" Width="14" Height="14"
                              Foreground="{DynamicResource HelixIconCutBrush}" />
                </Button>
                <Button Classes="toolButton" ToolTip.Tip="Copy" Command="{Binding CopyCommand}">
                    <PathIcon Data="{DynamicResource HelixIconCopyGeometry}" Width="14" Height="14"
                              Foreground="{DynamicResource HelixIconCopyBrush}" />
                </Button>
                <Button Classes="toolButton" ToolTip.Tip="Rename" Command="{Binding BeginRenameCommand}">
                    <PathIcon Data="{DynamicResource HelixIconRenameGeometry}" Width="14" Height="14"
                              Foreground="{DynamicResource HelixIconRenameBrush}" />
                </Button>
                <Button Classes="toolButton" ToolTip.Tip="Delete" Command="{Binding DeleteCommand}">
                    <PathIcon Data="{DynamicResource HelixIconDeleteGeometry}" Width="14" Height="14"
                              Foreground="{DynamicResource HelixIconDeleteBrush}" />
                </Button>
                <Button Classes="toolButton" ToolTip.Tip="Properties" Command="{Binding ShowPropertiesCommand}">
                    <PathIcon Data="{DynamicResource HelixIconInfoGeometry}" Width="14" Height="14" />
                </Button>
            </StackPanel>
            <Separator />
            <MenuItem Header="Open" Command="{Binding OpenCommand}" />
            <MenuItem Header="Open in new tab" Command="{Binding OpenInNewTabCommand}" />
            <MenuItem Header="Open in new Helix window" Command="{Binding OpenInNewWindowCommand}" />
            <MenuItem Header="Open in other pane" Command="{Binding OpenInOtherPaneCommand}" />
            <Separator />
            <MenuItem Header="Open in Terminal" Command="{Binding OpenInTerminalCommand}" />
            <Separator />
            <MenuItem Header="Sort by">
                <MenuItem Header="Name"
                          ToggleType="Radio"
                          IsChecked="{Binding IsSortByName}"
                          Command="{Binding SetSortColumnCommand}"
                          CommandParameter="{x:Static models:SortColumn.Name}" />
                <MenuItem Header="Date"
                          ToggleType="Radio"
                          IsChecked="{Binding IsSortByDate}"
                          Command="{Binding SetSortColumnCommand}"
                          CommandParameter="{x:Static models:SortColumn.Modified}" />
                <MenuItem Header="Type"
                          ToggleType="Radio"
                          IsChecked="{Binding IsSortByType}"
                          Command="{Binding SetSortColumnCommand}"
                          CommandParameter="{x:Static models:SortColumn.Type}" />
                <MenuItem Header="Size"
                          ToggleType="Radio"
                          IsChecked="{Binding IsSortBySize}"
                          Command="{Binding SetSortColumnCommand}"
                          CommandParameter="{x:Static models:SortColumn.Size}" />
                <Separator />
                <MenuItem Header="Ascending"
                          ToggleType="Radio"
                          IsChecked="{Binding IsSortAscending}"
                          Command="{Binding SetSortAscendingCommand}" />
                <MenuItem Header="Descending"
                          ToggleType="Radio"
                          IsChecked="{Binding IsSortDescendingActive}"
                          Command="{Binding SetSortDescendingCommand}" />
            </MenuItem>
            <Separator />
            <MenuItem Header="Restore" Command="{Binding RestoreFromRecycleBinCommand}" />
            <Separator />
            <MenuItem Header="Copy path" Command="{Binding CopyPathCommand}" />
            <MenuItem Header="Pin to sidebar" Command="{Binding PinToSidebarCommand}" />
            <MenuItem Header="Unpin from sidebar" Command="{Binding UnpinFromSidebarCommand}" />
            <MenuItem Header="Paste" Command="{Binding PasteCommand}" />
            <Separator />
            <MenuItem Header="Compress to ZIP" Command="{Binding CompressToZipCommand}" />
            <MenuItem Header="Extract here" Command="{Binding ExtractHereCommand}" />
            <Separator />
            <MenuItem Header="Layout">
                <MenuItem Header="Details" Command="{Binding SetViewModeCommand}" CommandParameter="{x:Static models:LayoutMode.Details}" />
                <MenuItem Header="List" Command="{Binding SetViewModeCommand}" CommandParameter="{x:Static models:LayoutMode.List}" />
                <MenuItem Header="Grid" Command="{Binding SetViewModeCommand}" CommandParameter="{x:Static models:LayoutMode.Grid}" />
                <MenuItem Header="Columns" Command="{Binding SetViewModeCommand}" CommandParameter="{x:Static models:LayoutMode.Miller}" />
            </MenuItem>
            <MenuItem Header="Folder color">
                <MenuItem Header="Red" Command="{Binding SetFolderColorCommand}" CommandParameter="#E81123" />
                <MenuItem Header="Orange" Command="{Binding SetFolderColorCommand}" CommandParameter="#F7630C" />
                <MenuItem Header="Green" Command="{Binding SetFolderColorCommand}" CommandParameter="#107C10" />
                <MenuItem Header="Blue" Command="{Binding SetFolderColorCommand}" CommandParameter="#0078D4" />
                <MenuItem Header="Purple" Command="{Binding SetFolderColorCommand}" CommandParameter="#8764B8" />
                <MenuItem Header="Clear color" Command="{Binding ClearFolderColorCommand}" />
            </MenuItem>
            <Separator />
            <MenuItem Header="Show more options" Command="{Binding ShowMoreOptionsCommand}" />
        </ContextMenu>
        <ContextMenu x:Key="EmptyAreaContextMenu"
                     x:CompileBindings="False"
                     Opening="OnEntryContextMenuOpening">
            <MenuItem Header="Restore" Command="{Binding RestoreFromRecycleBinCommand}" />
            <MenuItem Header="Empty Recycle Bin" Command="{Binding EmptyRecycleBinCommand}" />
            <Separator />
            <MenuItem Header="Paste" Command="{Binding PasteCommand}" />
            <MenuItem Header="New folder" Command="{Binding NewFolderCommand}" />
            <MenuItem Header="Refresh" Command="{Binding RefreshCommand}" />
            <MenuItem Header="Open in Terminal" Command="{Binding OpenInTerminalCommand}" />
            <Separator />
            <MenuItem Header="Sort by">
                <MenuItem Header="Name"
                          ToggleType="Radio"
                          IsChecked="{Binding IsSortByName}"
                          Command="{Binding SetSortColumnCommand}"
                          CommandParameter="{x:Static models:SortColumn.Name}" />
                <MenuItem Header="Date"
                          ToggleType="Radio"
                          IsChecked="{Binding IsSortByDate}"
                          Command="{Binding SetSortColumnCommand}"
                          CommandParameter="{x:Static models:SortColumn.Modified}" />
                <MenuItem Header="Type"
                          ToggleType="Radio"
                          IsChecked="{Binding IsSortByType}"
                          Command="{Binding SetSortColumnCommand}"
                          CommandParameter="{x:Static models:SortColumn.Type}" />
                <MenuItem Header="Size"
                          ToggleType="Radio"
                          IsChecked="{Binding IsSortBySize}"
                          Command="{Binding SetSortColumnCommand}"
                          CommandParameter="{x:Static models:SortColumn.Size}" />
                <Separator />
                <MenuItem Header="Ascending"
                          ToggleType="Radio"
                          IsChecked="{Binding IsSortAscending}"
                          Command="{Binding SetSortAscendingCommand}" />
                <MenuItem Header="Descending"
                          ToggleType="Radio"
                          IsChecked="{Binding IsSortDescendingActive}"
                          Command="{Binding SetSortDescendingCommand}" />
            </MenuItem>
            <Separator />
            <MenuItem Header="Layout">
                <MenuItem Header="Details" Command="{Binding SetViewModeCommand}" CommandParameter="{x:Static models:LayoutMode.Details}" />
                <MenuItem Header="List" Command="{Binding SetViewModeCommand}" CommandParameter="{x:Static models:LayoutMode.List}" />
                <MenuItem Header="Grid" Command="{Binding SetViewModeCommand}" CommandParameter="{x:Static models:LayoutMode.Grid}" />
                <MenuItem Header="Columns" Command="{Binding SetViewModeCommand}" CommandParameter="{x:Static models:LayoutMode.Miller}" />
            </MenuItem>
        </ContextMenu>
    </UserControl.Resources>

    <Grid Background="{DynamicResource HelixFileAreaBrush}"
          ContextMenu="{StaticResource EmptyAreaContextMenu}">
        <!-- Details view -->
        <DataGrid x:Name="DetailsGrid"
                  IsVisible="{Binding IsDetailsView}"
                  ItemsSource="{Binding Entries}"
                  AutoGenerateColumns="False"
                  IsReadOnly="True"
                  CanUserSortColumns="True"
                  CanUserResizeColumns="True"
                  SelectionMode="Extended"
                  GridLinesVisibility="Horizontal"
                  HeadersVisibility="Column"
                  RowHeight="{DynamicResource HelixRowHeight}"
                  DoubleTapped="OnItemActivated"
                  SelectionChanged="OnSelectionChanged"
                  Sorting="OnDetailsSorting"
                  PointerPressed="OnListPointerPressed"
                  PointerMoved="OnListPointerMoved"
                  PointerReleased="OnListPointerReleased"
                  Background="Transparent"
                  BorderThickness="0">
            <DataGrid.ContextMenu>
                <StaticResource ResourceKey="EntryContextMenu" />
            </DataGrid.ContextMenu>
            <DataGrid.Columns>
                <DataGridTemplateColumn Width="2*" Tag="Name" SortMemberPath="Name">
                    <DataGridTemplateColumn.HeaderTemplate>
                        <DataTemplate>
                            <controls:SortColumnHeader Title="Name"
                                                       Column="{x:Static models:SortColumn.Name}"
                                                       DataContext="{Binding DataContext, RelativeSource={RelativeSource AncestorType=DataGrid}}" />
                        </DataTemplate>
                    </DataGridTemplateColumn.HeaderTemplate>
                    <DataGridTemplateColumn.CellTemplate>
                        <DataTemplate x:DataType="vm:EntryItemViewModel">
                            <Grid ColumnDefinitions="Auto,*"
                                  VerticalAlignment="Center"
                                  Opacity="{Binding IsCut, Converter={StaticResource CutOpacityConverter}}"
                                  ToolTip.Tip="{Binding Name}">
                                <controls:EntryVisualView Grid.Column="0"
                                                          Width="16" Height="16" Margin="0,0,6,0"
                                                          Foreground="{Binding GitStatus, Converter={StaticResource GitFileStatusBrushConverter}}" />
                                <TextBlock Grid.Column="1"
                                           Text="{Binding DisplayName}"
                                           FontSize="{DynamicResource HelixEntryFontSize}"
                                           TextTrimming="CharacterEllipsis"
                                           VerticalAlignment="Center"
                                           Foreground="{Binding GitStatus, Converter={StaticResource GitFileStatusBrushConverter}}" />
                            </Grid>
                        </DataTemplate>
                    </DataGridTemplateColumn.CellTemplate>
                </DataGridTemplateColumn>
                <DataGridTextColumn Binding="{Binding ModifiedUtc, Converter={StaticResource RelativeTimeConverter}}"
                                    Width="140"
                                    Tag="Modified"
                                    SortMemberPath="ModifiedUtc"
                                    FontSize="{DynamicResource HelixEntryFontSize}">
                    <DataGridTextColumn.HeaderTemplate>
                        <DataTemplate>
                            <controls:SortColumnHeader Title="Date modified"
                                                       Column="{x:Static models:SortColumn.Modified}"
                                                       DataContext="{Binding DataContext, RelativeSource={RelativeSource AncestorType=DataGrid}}" />
                        </DataTemplate>
                    </DataGridTextColumn.HeaderTemplate>
                </DataGridTextColumn>
                <DataGridTextColumn Binding="{Binding TypeLabel}"
                                    Width="100"
                                    Tag="Type"
                                    SortMemberPath="Extension"
                                    FontSize="{DynamicResource HelixEntryFontSize}">
                    <DataGridTextColumn.HeaderTemplate>
                        <DataTemplate>
                            <controls:SortColumnHeader Title="Type"
                                                       Column="{x:Static models:SortColumn.Type}"
                                                       DataContext="{Binding DataContext, RelativeSource={RelativeSource AncestorType=DataGrid}}" />
                        </DataTemplate>
                    </DataGridTextColumn.HeaderTemplate>
                </DataGridTextColumn>
                <DataGridTemplateColumn Width="90" Tag="Size" SortMemberPath="SizeBytes">
                    <DataGridTemplateColumn.HeaderTemplate>
                        <DataTemplate>
                            <controls:SortColumnHeader Title="Size"
                                                       Column="{x:Static models:SortColumn.Size}"
                                                       DataContext="{Binding DataContext, RelativeSource={RelativeSource AncestorType=DataGrid}}" />
                        </DataTemplate>
                    </DataGridTemplateColumn.HeaderTemplate>
                    <DataGridTemplateColumn.CellTemplate>
                        <DataTemplate x:DataType="vm:EntryItemViewModel">
                            <TextBlock Text="{Binding Converter={StaticResource FileSizeConverter}}"
                                       FontSize="{DynamicResource HelixEntryFontSize}"
                                       VerticalAlignment="Center" />
                        </DataTemplate>
                    </DataGridTemplateColumn.CellTemplate>
                </DataGridTemplateColumn>
            </DataGrid.Columns>
        </DataGrid>

        <!-- List view -->
        <ListBox x:Name="ListView"
                 IsVisible="{Binding IsListView}"
                 ItemsSource="{Binding Entries}"
                 SelectionMode="Multiple"
                 Background="Transparent"
                 BorderThickness="0"
                 DoubleTapped="OnItemActivated"
                 SelectionChanged="OnSelectionChanged"
                 PointerPressed="OnListPointerPressed"
                 PointerMoved="OnListPointerMoved"
                 PointerReleased="OnListPointerReleased"
                 ScrollViewer.HorizontalScrollBarVisibility="Disabled">
            <ListBox.ContextMenu>
                <StaticResource ResourceKey="EntryContextMenu" />
            </ListBox.ContextMenu>
            <ListBox.ItemTemplate>
                <DataTemplate x:DataType="vm:EntryItemViewModel">
                    <Grid ColumnDefinitions="Auto,*"
                          Opacity="{Binding IsCut, Converter={StaticResource CutOpacityConverter}}"
                          ToolTip.Tip="{Binding Name}">
                        <controls:EntryVisualView Grid.Column="0"
                                                  Width="16" Height="16" Margin="0,0,6,0"
                                                  Foreground="{Binding GitStatus, Converter={StaticResource GitFileStatusBrushConverter}}" />
                        <TextBlock Grid.Column="1"
                                   Text="{Binding DisplayName}"
                                   FontSize="{DynamicResource HelixEntryFontSize}"
                                   TextTrimming="CharacterEllipsis"
                                   VerticalAlignment="Center"
                                   Foreground="{Binding GitStatus, Converter={StaticResource GitFileStatusBrushConverter}}" />
                    </Grid>
                </DataTemplate>
            </ListBox.ItemTemplate>
            <ListBox.Styles>
                <Style Selector="ListBoxItem">
                    <Setter Property="Padding" Value="8,1" />
                    <Setter Property="MinHeight" Value="22" />
                    <Setter Property="FontSize" Value="{DynamicResource HelixEntryFontSize}" />
                </Style>
            </ListBox.Styles>
        </ListBox>

        <!-- Grid view -->
        <Grid IsVisible="{Binding IsGridView}" RowDefinitions="*,Auto">
            <controls:VirtualizingFileGrid x:Name="GridView"
                     Grid.Row="0"
                     ItemsSource="{Binding Entries}"
                     ItemSize="{Binding ThumbnailSize}"
                     Background="Transparent"
                     BorderThickness="0"
                     PointerWheelChanged="OnGridPointerWheel"
                     PointerPressed="OnListPointerPressed"
                     PointerMoved="OnListPointerMoved"
                     PointerReleased="OnListPointerReleased"
                     ScrollViewer.HorizontalScrollBarVisibility="Disabled">
                <controls:VirtualizingFileGrid.ContextMenu>
                    <StaticResource ResourceKey="EntryContextMenu" />
                </controls:VirtualizingFileGrid.ContextMenu>
                <controls:VirtualizingFileGrid.ItemTemplate>
                    <DataTemplate x:DataType="vm:EntryItemViewModel" x:CompileBindings="False">
                        <Border Width="{Binding DataContext.ThumbnailSize, RelativeSource={RelativeSource AncestorType=controls:VirtualizingFileGrid}}"
                                Margin="6"
                                Padding="4"
                                CornerRadius="6"
                                ClipToBounds="True"
                                PointerPressed="OnGridItemPointerPressed"
                                DoubleTapped="OnGridItemDoubleTapped">
                            <Panel>
                                <Border CornerRadius="6"
                                        Background="{Binding FullPath, Converter={StaticResource FolderColorConverter}}" />
                                <Border CornerRadius="6"
                                        Classes="selectionActive"
                                        Background="{DynamicResource HelixSelectionFillBrush}"
                                        IsVisible="{Binding IsSelected}"
                                        IsHitTestVisible="False" />
                                <Border CornerRadius="6"
                                        BorderBrush="{DynamicResource HelixAccentBrush}"
                                        BorderThickness="2"
                                        IsVisible="{Binding IsSelected}"
                                        IsHitTestVisible="False" />
                                <PathIcon Data="{DynamicResource HelixIconCheckmarkGeometry}"
                                          Width="14" Height="14"
                                          HorizontalAlignment="Right"
                                          VerticalAlignment="Top"
                                          Margin="4"
                                          Foreground="{DynamicResource HelixAccentBrush}"
                                          IsVisible="{Binding IsSelected}"
                                          IsHitTestVisible="False" />
                                <StackPanel Spacing="4" ToolTip.Tip="{Binding Name}"
                                            Opacity="{Binding IsCut, Converter={StaticResource CutOpacityConverter}}">
                                <controls:EntryVisualView Width="{Binding DataContext.ThumbnailSize, RelativeSource={RelativeSource AncestorType=controls:VirtualizingFileGrid}}"
                                                          Height="{Binding DataContext.ThumbnailSize, RelativeSource={RelativeSource AncestorType=controls:VirtualizingFileGrid}}"
                                                          HorizontalAlignment="Center"
                                                          Foreground="{Binding GitStatus, Converter={StaticResource GitFileStatusBrushConverter}}" />
                                <TextBlock Text="{Binding DisplayName}"
                                           FontSize="{DynamicResource HelixEntryFontSize}"
                                           TextAlignment="Center"
                                           TextWrapping="Wrap"
                                           MaxLines="2"
                                           TextTrimming="CharacterEllipsis"
                                           HorizontalAlignment="Stretch"
                                           Foreground="{Binding GitStatus, Converter={StaticResource GitFileStatusBrushConverter}}" />
                                </StackPanel>
                            </Panel>
                        </Border>
                    </DataTemplate>
                </controls:VirtualizingFileGrid.ItemTemplate>
            </controls:VirtualizingFileGrid>

            <Border Grid.Row="1"
                    Background="{DynamicResource HelixToolbarBrush}"
                    BorderBrush="{DynamicResource HelixBorderColor}"
                    BorderThickness="0,1,0,0"
                    Padding="12,4">
                <StackPanel Orientation="Horizontal" Spacing="8" HorizontalAlignment="Right">
                    <PathIcon Data="{DynamicResource HelixIconDocumentGeometry}"
                              Width="12" Height="12" Opacity="0.6" />
                    <Slider Width="140"
                            Minimum="32" Maximum="256"
                            Value="{Binding ThumbnailSize, Mode=TwoWay}"
                            VerticalAlignment="Center"
                            ToolTip.Tip="Thumbnail size (Ctrl+Scroll)" />
                </StackPanel>
            </Border>
        </Grid>

        <!-- Miller columns -->
        <ScrollViewer x:Name="MillerScroll"
                      IsVisible="{Binding IsMillerView}"
                      HorizontalScrollBarVisibility="Auto"
                      VerticalScrollBarVisibility="Disabled">
            <controls:MillerColumnPanel x:Name="MillerPanel"
                                        ColumnWidth="250"
                                        ColumnSpacing="4"
                                        ColumnActivated="OnMillerColumnActivated" />
        </ScrollViewer>

        <!-- Rename overlay -->
        <Border IsVisible="{Binding IsRenaming}"
                VerticalAlignment="Top" HorizontalAlignment="Center"
                Margin="0,60,0,0"
                Background="{DynamicResource HelixContentCardBrush}"
                BorderBrush="{DynamicResource HelixAccentBrush}"
                BorderThickness="1"
                CornerRadius="6"
                Padding="12,8"
                BoxShadow="0 4 12 0 #30000000">
            <StackPanel Orientation="Horizontal" Spacing="8">
                <TextBox x:Name="RenameBox"
                         Text="{Binding RenameText, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                         Width="250"
                         BorderThickness="0"
                         Background="Transparent"
                         Padding="0"
                         VerticalAlignment="Center"
                         KeyDown="OnRenameKeyDown" />
                <Button Content="OK"
                        Command="{Binding CommitRenameCommand}"
                        Padding="8,4"
                        Background="{DynamicResource HelixAccentBrush}"
                        Foreground="White"
                        BorderThickness="0"
                        Cursor="Hand" />
                <Button Content="Cancel"
                        Command="{Binding CancelRenameCommand}"
                        Padding="8,4"
                        Background="Transparent"
                        BorderThickness="1"
                        BorderBrush="{DynamicResource HelixBorderColor}"
                        Cursor="Hand" />
            </StackPanel>
        </Border>

        <!-- Quick filter pill (Ctrl+F) -->
        <Border IsVisible="{Binding IsFilterVisible}"
                VerticalAlignment="Top" HorizontalAlignment="Right"
                Margin="0,8,16,0"
                Background="{DynamicResource HelixContentCardBrush}"
                BorderBrush="{DynamicResource HelixAccentBrush}"
                BorderThickness="1"
                CornerRadius="14"
                Padding="10,4"
                BoxShadow="0 2 8 0 #30000000">
            <StackPanel Orientation="Horizontal" Spacing="6">
                <PathIcon Data="{DynamicResource HelixIconSearchGeometry}"
                          Width="14" Height="14" Opacity="0.6" VerticalAlignment="Center" />
                <TextBox x:Name="FilterBox"
                         Text="{Binding FilterText, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                         Width="200"
                         BorderThickness="0"
                         Background="Transparent"
                         Padding="0"
                         VerticalAlignment="Center"
                         PlaceholderText="Filter items…"
                         KeyDown="OnFilterBoxKeyDown" />
                <Button Content="✕"
                        Padding="4,0"
                        Background="Transparent"
                        BorderThickness="0"
                        Cursor="Hand"
                        FontSize="12"
                        Opacity="0.6"
                        Click="OnFilterCloseClick" />
            </StackPanel>
        </Border>

        <!-- Loading overlay -->
        <controls:SelectionMarquee x:Name="SelectionMarquee"
                                   IsHitTestVisible="False"
                                   ZIndex="50" />

        <Border IsVisible="{Binding IsLoading}"
                Background="#20000000"
                IsHitTestVisible="False">
            <TextBlock Text="Loading…"
                       HorizontalAlignment="Center"
                       VerticalAlignment="Center"
                       Opacity="0.7" />
        </Border>
    </Grid>
</UserControl>
