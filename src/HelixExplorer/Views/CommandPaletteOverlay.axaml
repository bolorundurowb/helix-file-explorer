<Panel xmlns="https://github.com/avaloniaui"
       xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
       xmlns:vm="using:HelixExplorer.ViewModels"
       x:Class="HelixExplorer.Views.CommandPaletteOverlay"
       x:DataType="vm:MainWindowViewModel"
       IsVisible="False"
       Background="#80000000"
       ZIndex="100"
       PointerPressed="OnRootPointerPressed">
    <Border Width="560" MaxHeight="420"
            VerticalAlignment="Top"
            Margin="0,80,0,0"
            HorizontalAlignment="Center"
            Background="{DynamicResource HelixContentCardBrush}"
            BorderBrush="{DynamicResource HelixAccentBrush}"
            BorderThickness="1"
            CornerRadius="8"
            Padding="0">
        <Grid RowDefinitions="Auto,*">
            <TextBox x:Name="QueryBox"
                     Grid.Row="0"
                     Text="{Binding CommandPaletteQuery, Mode=TwoWay}"
                     PlaceholderText="Type a command…"
                     KeyDown="OnQueryKeyDown"
                     Padding="12,10"
                     Background="Transparent"
                     BorderThickness="0,0,0,1" />
            <ListBox x:Name="ResultsList"
                     Grid.Row="1"
                     ItemsSource="{Binding FilteredCommands}"
                     SelectionMode="Single"
                     DoubleTapped="OnResultDoubleTapped">
                <ListBox.ItemTemplate>
                    <DataTemplate x:DataType="vm:CommandItem">
                        <Grid ColumnDefinitions="*,Auto,Auto" Margin="4,2">
                            <TextBlock Grid.Column="0" Text="{Binding Title}" FontWeight="Medium" />
                            <TextBlock Grid.Column="1"
                                       Text="{Binding Shortcut}"
                                       Opacity="0.6"
                                       Margin="8,0,0,0" />
                            <TextBlock Grid.Column="2"
                                       Text="{Binding Category}"
                                       Opacity="0.7"
                                       Margin="8,0,0,0" />
                        </Grid>
                    </DataTemplate>
                </ListBox.ItemTemplate>
            </ListBox>
        </Grid>
    </Border>
</Panel>
