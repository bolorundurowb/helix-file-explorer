<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:HelixExplorer.ViewModels"
             xmlns:models="using:HelixExplorer.Core.Models"
             x:Class="HelixExplorer.Views.PaneView"
             x:DataType="vm:PaneViewModel"
             Focusable="True"
             KeyDown="OnPaneKeyDown"
             DragDrop.AllowDrop="True"
             DragDrop.Drop="OnDrop"
             DragDrop.DragOver="OnDragOver">

    <Grid>
        <!-- Details view -->
        <DataGrid x:Name="DetailsGrid"
                  IsVisible="{Binding IsDetailsView}"
                  ItemsSource="{Binding Entries}"
                  AutoGenerateColumns="False"
                  IsReadOnly="True"
                  CanUserSortColumns="True"
                  CanUserResizeColumns="True"
                  SelectionMode="Extended"
                  GridLinesVisibility="Horizontal"
                  HeadersVisibility="Column"
                  RowHeight="{DynamicResource HelixRowHeight}"
                  DoubleTapped="OnItemActivated"
                  SelectionChanged="OnSelectionChanged"
                  Sorting="OnDetailsSorting"
                  PointerPressed="OnListPointerPressed"
                  PointerMoved="OnListPointerMoved"
                  PointerReleased="OnListPointerReleased"
                  Background="Transparent"
                  BorderThickness="0">
            <DataGrid.Columns>
                <DataGridTemplateColumn Header="Name" Width="2*" Tag="Name" SortMemberPath="Name">
                    <DataGridTemplateColumn.CellTemplate>
                        <DataTemplate x:DataType="models:FileSystemEntry">
                            <Grid ColumnDefinitions="Auto,*"
                                  VerticalAlignment="Center"
                                  ToolTip.Tip="{Binding Name}">
                                <PathIcon Grid.Column="0"
                                          Data="{Binding Converter={StaticResource EntryIconConverter}}"
                                          Width="14" Height="14" Margin="0,0,6,0"
                                          Foreground="{DynamicResource HelixAccentBrush}" />
                                <TextBlock Grid.Column="1"
                                           Text="{Binding Name}"
                                           FontSize="{DynamicResource HelixEntryFontSize}"
                                           TextTrimming="CharacterEllipsis"
                                           VerticalAlignment="Center" />
                            </Grid>
                        </DataTemplate>
                    </DataGridTemplateColumn.CellTemplate>
                </DataGridTemplateColumn>
                <DataGridTextColumn Header="Date modified"
                                    Binding="{Binding ModifiedUtc, Converter={StaticResource RelativeTimeConverter}}"
                                    Width="140"
                                    Tag="Modified"
                                    SortMemberPath="ModifiedUtc"
                                    FontSize="{DynamicResource HelixEntryFontSize}" />
                <DataGridTextColumn Header="Type"
                                    Binding="{Binding TypeLabel}"
                                    Width="100"
                                    Tag="Type"
                                    SortMemberPath="Extension"
                                    FontSize="{DynamicResource HelixEntryFontSize}" />
                <DataGridTemplateColumn Header="Size" Width="90" Tag="Size" SortMemberPath="SizeBytes">
                    <DataGridTemplateColumn.CellTemplate>
                        <DataTemplate x:DataType="models:FileSystemEntry">
                            <TextBlock Text="{Binding Converter={StaticResource FileSizeConverter}}"
                                       FontSize="{DynamicResource HelixEntryFontSize}"
                                       VerticalAlignment="Center" />
                        </DataTemplate>
                    </DataGridTemplateColumn.CellTemplate>
                </DataGridTemplateColumn>
            </DataGrid.Columns>
        </DataGrid>

        <!-- List view -->
        <ListBox x:Name="ListView"
                 IsVisible="{Binding IsListView}"
                 ItemsSource="{Binding Entries}"
                 SelectionMode="Multiple"
                 Background="Transparent"
                 BorderThickness="0"
                 DoubleTapped="OnItemActivated"
                 SelectionChanged="OnSelectionChanged"
                 PointerPressed="OnListPointerPressed"
                 PointerMoved="OnListPointerMoved"
                 PointerReleased="OnListPointerReleased"
                 ScrollViewer.HorizontalScrollBarVisibility="Disabled">
            <ListBox.ItemTemplate>
                <DataTemplate x:DataType="models:FileSystemEntry">
                    <Grid ColumnDefinitions="Auto,*"
                          ToolTip.Tip="{Binding Name}">
                        <PathIcon Grid.Column="0"
                                  Data="{Binding Converter={StaticResource EntryIconConverter}}"
                                  Width="14" Height="14" Margin="0,0,6,0"
                                  Foreground="{DynamicResource HelixAccentBrush}" />
                        <TextBlock Grid.Column="1"
                                   Text="{Binding Name}"
                                   FontSize="{DynamicResource HelixEntryFontSize}"
                                   TextTrimming="CharacterEllipsis"
                                   VerticalAlignment="Center" />
                    </Grid>
                </DataTemplate>
            </ListBox.ItemTemplate>
            <ListBox.Styles>
                <Style Selector="ListBoxItem">
                    <Setter Property="Padding" Value="8,1" />
                    <Setter Property="MinHeight" Value="22" />
                    <Setter Property="FontSize" Value="{DynamicResource HelixEntryFontSize}" />
                </Style>
            </ListBox.Styles>
        </ListBox>

        <!-- Grid view -->
        <Grid IsVisible="{Binding IsGridView}" RowDefinitions="*,Auto">
            <ListBox x:Name="GridView"
                     Grid.Row="0"
                     ItemsSource="{Binding Entries}"
                     SelectionMode="Multiple"
                     Background="Transparent"
                     BorderThickness="0"
                     DoubleTapped="OnItemActivated"
                     SelectionChanged="OnSelectionChanged"
                     PointerWheelChanged="OnGridPointerWheel"
                     PointerPressed="OnListPointerPressed"
                     PointerMoved="OnListPointerMoved"
                     PointerReleased="OnListPointerReleased"
                     ScrollViewer.HorizontalScrollBarVisibility="Disabled">
                <ListBox.ItemsPanel>
                    <ItemsPanelTemplate>
                        <WrapPanel Orientation="Horizontal" />
                    </ItemsPanelTemplate>
                </ListBox.ItemsPanel>
                <ListBox.ItemTemplate>
                    <DataTemplate x:DataType="models:FileSystemEntry" x:CompileBindings="False">
                        <StackPanel Width="{Binding DataContext.ThumbnailSize, RelativeSource={RelativeSource AncestorType=ListBox}}"
                                    Margin="6" Spacing="4"
                                    ToolTip.Tip="{Binding Name}">
                            <PathIcon Data="{Binding Converter={StaticResource EntryIconConverter}}"
                                      Width="{Binding DataContext.ThumbnailSize, RelativeSource={RelativeSource AncestorType=ListBox}}"
                                      Height="{Binding DataContext.ThumbnailSize, RelativeSource={RelativeSource AncestorType=ListBox}}"
                                      Foreground="{DynamicResource HelixAccentBrush}" />
                            <TextBlock Text="{Binding Name}"
                                       FontSize="{DynamicResource HelixEntryFontSize}"
                                       TextAlignment="Center"
                                       TextWrapping="Wrap"
                                       MaxLines="2"
                                       TextTrimming="CharacterEllipsis"
                                       HorizontalAlignment="Stretch" />
                        </StackPanel>
                    </DataTemplate>
                </ListBox.ItemTemplate>
                <ListBox.Styles>
                    <Style Selector="ListBoxItem">
                        <Setter Property="Padding" Value="2" />
                    </Style>
                </ListBox.Styles>
            </ListBox>

            <Border Grid.Row="1"
                    Background="{DynamicResource HelixToolbarBrush}"
                    BorderBrush="{DynamicResource HelixBorderColor}"
                    BorderThickness="0,1,0,0"
                    Padding="12,4">
                <StackPanel Orientation="Horizontal" Spacing="8" HorizontalAlignment="Right">
                    <PathIcon Data="M13,9V3.5L18.5,9M6,2C4.89,2 4,2.89 4,4V20A2,2 0 0,0 6,22H18A2,2 0 0,0 20,20V8L14,2H6Z"
                              Width="12" Height="12" Opacity="0.6" />
                    <Slider Width="140"
                            Minimum="32" Maximum="256"
                            Value="{Binding ThumbnailSize, Mode=TwoWay}"
                            VerticalAlignment="Center"
                            ToolTip.Tip="Thumbnail size (Ctrl+Scroll)" />
                </StackPanel>
            </Border>
        </Grid>

        <!-- Rename overlay -->
        <Border IsVisible="{Binding IsRenaming}"
                VerticalAlignment="Top" HorizontalAlignment="Center"
                Margin="0,60,0,0"
                Background="{DynamicResource HelixContentCardBrush}"
                BorderBrush="{DynamicResource HelixAccentBrush}"
                BorderThickness="1"
                CornerRadius="6"
                Padding="12,8"
                BoxShadow="0 4 12 0 #30000000">
            <StackPanel Orientation="Horizontal" Spacing="8">
                <TextBox x:Name="RenameBox"
                         Text="{Binding RenameText, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                         Width="250"
                         BorderThickness="0"
                         Background="Transparent"
                         Padding="0"
                         VerticalAlignment="Center"
                         KeyDown="OnRenameKeyDown" />
                <Button Content="OK"
                        Command="{Binding CommitRenameCommand}"
                        Padding="8,4"
                        Background="{DynamicResource HelixAccentBrush}"
                        Foreground="White"
                        BorderThickness="0"
                        Cursor="Hand" />
                <Button Content="Cancel"
                        Command="{Binding CancelRenameCommand}"
                        Padding="8,4"
                        Background="Transparent"
                        BorderThickness="1"
                        BorderBrush="{DynamicResource HelixBorderColor}"
                        Cursor="Hand" />
            </StackPanel>
        </Border>

        <!-- Quick filter pill (Ctrl+F) -->
        <Border IsVisible="{Binding IsFilterVisible}"
                VerticalAlignment="Top" HorizontalAlignment="Right"
                Margin="0,8,16,0"
                Background="{DynamicResource HelixContentCardBrush}"
                BorderBrush="{DynamicResource HelixAccentBrush}"
                BorderThickness="1"
                CornerRadius="14"
                Padding="10,4"
                BoxShadow="0 2 8 0 #30000000">
            <StackPanel Orientation="Horizontal" Spacing="6">
                <PathIcon Data="M9.5,3A6.5,6.5 0 0,1 16,9.5C16,11.11 15.41,12.59 14.44,13.73L14.71,14H15.5L20.5,19L19,20.5L14,15.5V14.71L13.73,14.44C12.59,15.41 11.11,16 9.5,16A6.5,6.5 0 0,1 3,9.5A6.5,6.5 0 0,1 9.5,3M9.5,5C7,5 5,7 5,9.5C5,12 7,14 9.5,14C12,14 14,12 14,9.5C14,7 12,5 9.5,5Z"
                          Width="14" Height="14" Opacity="0.6" VerticalAlignment="Center" />
                <TextBox x:Name="FilterBox"
                         Text="{Binding FilterText, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                         Width="200"
                         BorderThickness="0"
                         Background="Transparent"
                         Padding="0"
                         VerticalAlignment="Center"
                         PlaceholderText="Filter items…"
                         KeyDown="OnFilterBoxKeyDown" />
                <Button Content="✕"
                        Padding="4,0"
                        Background="Transparent"
                        BorderThickness="0"
                        Cursor="Hand"
                        FontSize="12"
                        Opacity="0.6"
                        Click="OnFilterCloseClick" />
            </StackPanel>
        </Border>

        <!-- Loading overlay -->
        <Border IsVisible="{Binding IsLoading}"
                Background="#20000000"
                IsHitTestVisible="False">
            <TextBlock Text="Loading…"
                       HorizontalAlignment="Center"
                       VerticalAlignment="Center"
                       Opacity="0.7" />
        </Border>
    </Grid>
</UserControl>
