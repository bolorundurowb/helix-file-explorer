<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="using:HelixExplorer.ViewModels"
        xmlns:views="using:HelixExplorer.Views"
        xmlns:models="using:HelixExplorer.Core.Models"
        x:Class="HelixExplorer.Views.MainWindow"
        x:DataType="vm:MainWindowViewModel"
        Title="{Binding Title}"
        Width="1280" Height="800"
        MinWidth="800" MinHeight="500"
        WindowStartupLocation="CenterScreen"
        ExtendClientAreaToDecorationsHint="True"
        ExtendClientAreaTitleBarHeightHint="32"
        WindowDecorations="Full"
        Background="{DynamicResource HelixChromeBrush}">

    <Window.Styles>
        <Style Selector="WindowDrawnDecorations /template/ Panel#PART_TitleTextPanel > TextBlock">
            <Setter Property="IsVisible" Value="False" />
        </Style>
        <Style Selector="WindowDrawnDecorations /template/ Button#PART_FullScreenButton">
            <Setter Property="IsVisible" Value="False" />
        </Style>
        <Style Selector="WindowDrawnDecorations /template/ Button#PART_PopoverFullScreenButton">
            <Setter Property="IsVisible" Value="False" />
        </Style>
    </Window.Styles>

    <Window.KeyBindings>
        <KeyBinding Gesture="Ctrl+Shift+P" Command="{Binding ToggleCommandPaletteCommand}" />
        <KeyBinding Gesture="Ctrl+Shift+T" Command="{Binding ToggleThemeCommand}" />
        <KeyBinding Gesture="Ctrl+T" Command="{Binding NewTabCommand}" />
        <KeyBinding Gesture="Ctrl+W" Command="{Binding CloseSelectedTabCommand}" />
        <KeyBinding Gesture="Ctrl+D" Command="{Binding ToggleDualPaneCommand}" />
        <KeyBinding Gesture="Ctrl+F" Command="{Binding FocusSearchCommand}" />
        <KeyBinding Gesture="Ctrl+X" Command="{Binding CutCommand}" />
        <KeyBinding Gesture="Ctrl+C" Command="{Binding CopyCommand}" />
        <KeyBinding Gesture="Ctrl+V" Command="{Binding PasteCommand}" />
        <KeyBinding Gesture="Delete" Command="{Binding DeleteCommand}" />
        <KeyBinding Gesture="Shift+Delete" Command="{Binding DeletePermanentlyCommand}" />
        <KeyBinding Gesture="Ctrl+Tab" Command="{Binding SelectNextTabCommand}" />
        <KeyBinding Gesture="Ctrl+Shift+Tab" Command="{Binding SelectPreviousTabCommand}" />
        <KeyBinding Gesture="F2" Command="{Binding RenameCommand}" />
        <KeyBinding Gesture="Ctrl+Shift+N" Command="{Binding NewFolderCommand}" />
        <KeyBinding Gesture="Ctrl+Shift+C" Command="{Binding CopyPathCommand}" />
        <KeyBinding Gesture="Ctrl+A" Command="{Binding SelectAllCommand}" />
    </Window.KeyBindings>

    <Grid>
        <Grid>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="{Binding SidebarWidth, Mode=TwoWay}" MinWidth="160" MaxWidth="480" />
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>
            <Border x:Name="SidebarBorder"
                    Grid.Column="0"
                    Background="{DynamicResource HelixSidebarBrush}"
                    BorderBrush="{DynamicResource HelixBorderColor}"
                    BorderThickness="0,0,1,0">
                <DockPanel>
                    <Button DockPanel.Dock="Bottom"
                            Command="{Binding OpenSettingsCommand}"
                            Padding="12,8"
                            Background="Transparent"
                            BorderBrush="{DynamicResource HelixBorderColor}"
                            BorderThickness="0,1,0,0"
                            HorizontalAlignment="Stretch"
                            HorizontalContentAlignment="Left"
                            Cursor="Hand">
                        <StackPanel Orientation="Horizontal" Spacing="10">
                            <PathIcon Data="{DynamicResource HelixIconSettingsGeometry}" Width="16" Height="16" />
                            <TextBlock Text="Settings"
                                       VerticalAlignment="Center"
                                       FontSize="{DynamicResource HelixSidebarFontSize}" />
                        </StackPanel>
                    </Button>

                    <ScrollViewer VerticalScrollBarVisibility="Auto">
                        <ItemsControl ItemsSource="{Binding SidebarItems}" Margin="0,8">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate x:DataType="vm:SidebarItemViewModel">
                                    <Panel>
                                        <TextBlock Text="{Binding Title}"
                                                   IsVisible="{Binding IsSectionHeader}"
                                                   Padding="12,12,12,4"
                                                   FontSize="{DynamicResource HelixSidebarSectionFontSize}"
                                                   Opacity="0.5"
                                                   FontWeight="SemiBold" />
                                        <Border IsVisible="{Binding !IsSectionHeader}"
                                                Padding="0"
                                                Cursor="Hand"
                                                ToolTip.Tip="{Binding ToolTip}"
                                                PointerPressed="OnSidebarItemPressed">
                                            <Border.ContextMenu>
                                                <ContextMenu Opening="OnSidebarContextMenuOpening">
                                                    <MenuItem Header="Pin to sidebar" Click="OnSidebarPinClick" />
                                                    <MenuItem Header="Unpin from sidebar" Click="OnSidebarUnpinClick" />
                                                    <Separator />
                                                    <MenuItem Header="Color">
                                                        <MenuItem Header="Red" Tag="#E81123" Click="OnSidebarSetColorClick" />
                                                        <MenuItem Header="Orange" Tag="#F7630C" Click="OnSidebarSetColorClick" />
                                                        <MenuItem Header="Green" Tag="#107C10" Click="OnSidebarSetColorClick" />
                                                        <MenuItem Header="Blue" Tag="#0078D4" Click="OnSidebarSetColorClick" />
                                                        <MenuItem Header="Purple" Tag="#8764B8" Click="OnSidebarSetColorClick" />
                                                    </MenuItem>
                                                    <MenuItem Header="Clear color" Click="OnSidebarClearColorClick" />
                                                </ContextMenu>
                                            </Border.ContextMenu>
                                            <Grid ColumnDefinitions="3,Auto,*" MinHeight="32">
                                                <Border Grid.Column="0"
                                                        Background="{DynamicResource HelixSelectionBarBrush}"
                                                        IsVisible="{Binding IsSelected}"
                                                        CornerRadius="0,2,2,0" />
                                                <PathIcon Grid.Column="1"
                                                          Width="16"
                                                          Height="16"
                                                          Margin="10,0,6,0"
                                                          VerticalAlignment="Center"
                                                          IsVisible="{Binding !HasIcon}"
                                                          Data="{DynamicResource HelixFolderIconGeometry}"
                                                          Foreground="{Binding Path, Converter={StaticResource FolderIconBrushConverter}}" />
                                                <Image Grid.Column="1"
                                                       Source="{Binding Icon}"
                                                       Width="16"
                                                       Height="16"
                                                       Margin="10,0,6,0"
                                                       VerticalAlignment="Center"
                                                       IsVisible="{Binding HasIcon}" />
                                                <Border Grid.Column="2"
                                                        Padding="10,6,8,6"
                                                        Background="{Binding IsSelected, Converter={StaticResource BoolToSidebarBrushConverter}}">
                                                    <TextBlock Text="{Binding Title}"
                                                               VerticalAlignment="Center"
                                                               FontSize="{DynamicResource HelixSidebarFontSize}"
                                                               TextTrimming="CharacterEllipsis" />
                                                </Border>
                                            </Grid>
                                        </Border>
                                    </Panel>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </ScrollViewer>
                </DockPanel>
            </Border>

            <GridSplitter Grid.Column="1"
                          Width="4"
                          ResizeDirection="Columns"
                          Background="Transparent" />

            <DockPanel Grid.Column="2" LastChildFill="True">

        <!-- Tab Strip: right padding reserves the caption-button cluster (3×46px). -->
        <Border DockPanel.Dock="Top"
                Background="{DynamicResource HelixTabStripBrush}"
                Padding="{DynamicResource HelixTabStripPadding}"
                Height="{DynamicResource HelixTitleBarHeight}"
                WindowDecorationProperties.ElementRole="TitleBar">
            <Grid ColumnDefinitions="Auto,*">
                <Button Grid.Column="0"
                        Command="{Binding NewTabCommand}"
                        Padding="8,0"
                        Margin="0,0,4,0"
                        Background="Transparent"
                        BorderThickness="0"
                        VerticalAlignment="Center"
                        Cursor="Hand"
                        ToolTip.Tip="New Tab (Ctrl+T)"
                        WindowDecorationProperties.ElementRole="User">
                    <PathIcon Data="{DynamicResource HelixIconAddGeometry}"
                              Width="12" Height="12"
                              Opacity="0.75" />
                </Button>

                <ListBox x:Name="TabStrip"
                         Grid.Column="1"
                         HorizontalAlignment="Stretch"
                         ItemsSource="{Binding Tabs}"
                         SelectedItem="{Binding SelectedTab, Mode=TwoWay}"
                         Background="Transparent"
                         BorderThickness="0"
                         Padding="0"
                         PointerWheelChanged="OnTabStripWheel"
                         ScrollViewer.VerticalScrollBarVisibility="Disabled"
                         ScrollViewer.HorizontalScrollBarVisibility="Auto"
                         WindowDecorationProperties.ElementRole="User">
                    <ListBox.ItemsPanel>
                        <ItemsPanelTemplate>
                            <StackPanel Orientation="Horizontal" Spacing="2" />
                        </ItemsPanelTemplate>
                    </ListBox.ItemsPanel>
                    <ListBox.Styles>
                        <Style Selector="ListBoxItem">
                            <Setter Property="Padding" Value="0" />
                            <Setter Property="Margin" Value="0,0,2,0" />
                            <Setter Property="Background" Value="Transparent" />
                            <Setter Property="VerticalAlignment" Value="Bottom" />
                        </Style>
                        <Style Selector="ListBoxItem /template/ ContentPresenter">
                            <Setter Property="Background" Value="Transparent" />
                        </Style>
                        <Style Selector="ListBoxItem:not(:selected) Border#TabChip">
                            <Setter Property="Opacity" Value="0.58" />
                            <Setter Property="Background" Value="Transparent" />
                            <Setter Property="BorderThickness" Value="0" />
                        </Style>
                        <Style Selector="ListBoxItem:selected Border#TabChip">
                            <Setter Property="Opacity" Value="1" />
                            <Setter Property="Background" Value="{DynamicResource HelixContentCardBrush}" />
                            <Setter Property="BorderBrush" Value="{DynamicResource HelixBorderColor}" />
                            <Setter Property="BorderThickness" Value="1,1,1,0" />
                            <Setter Property="Margin" Value="0,2,0,-1" />
                        </Style>
                        <Style Selector="ListBoxItem:selected Border#TabActiveBar">
                            <Setter Property="IsVisible" Value="True" />
                        </Style>
                        <Style Selector="ListBoxItem:selected TextBlock#TabTitle">
                            <Setter Property="FontWeight" Value="SemiBold" />
                        </Style>
                        <Style Selector="ListBoxItem:not(:selected) TextBlock#TabTitle">
                            <Setter Property="Opacity" Value="0.75" />
                        </Style>
                    </ListBox.Styles>
                    <ListBox.ItemTemplate>
                        <DataTemplate x:DataType="vm:TabViewModel">
                            <Border x:Name="TabChip"
                                    CornerRadius="8,8,0,0"
                                    Background="Transparent"
                                    BorderThickness="0"
                                    Padding="12,6,12,4"
                                    MinWidth="150" MaxWidth="220"
                                    PointerReleased="OnTabPointerReleased"
                                    WindowDecorationProperties.ElementRole="User">
                                <Grid RowDefinitions="Auto,Auto,Auto">
                                    <StackPanel Grid.Row="0" Orientation="Horizontal" Spacing="8">
                                        <PathIcon Data="{DynamicResource HelixFolderIconGeometry}"
                                                  Width="14" Height="14"
                                                  Foreground="{DynamicResource HelixAccentBrush}" />
                                        <TextBlock x:Name="TabTitle"
                                                   Text="{Binding Title}"
                                                   VerticalAlignment="Center"
                                                   TextTrimming="CharacterEllipsis"
                                                   MaxWidth="140" />
                                        <Button Command="{Binding CloseCommand}"
                                                Padding="2" Background="Transparent" BorderThickness="0"
                                                FontSize="12" Opacity="0.6" Cursor="Hand"
                                                ToolTip.Tip="Close tab (Ctrl+W)"
                                                WindowDecorationProperties.ElementRole="User">
                                            <TextBlock Text="✕" />
                                        </Button>
                                    </StackPanel>
                                    <Border Grid.Row="1"
                                            Height="3"
                                            CornerRadius="2"
                                            Margin="0,4,0,0"
                                            Background="{Binding TintBrush}"
                                            IsVisible="{Binding HasTint}" />
                                    <Border x:Name="TabActiveBar"
                                            Grid.Row="2"
                                            Height="2"
                                            CornerRadius="1"
                                            Margin="10,4,10,0"
                                            Background="{DynamicResource HelixAccentBrush}"
                                            IsVisible="False" />
                                </Grid>
                                <Border.ContextMenu>
                                    <ContextMenu>
                                        <MenuItem Header="Tint">
                                            <MenuItem Header="Red"    Command="{Binding SetTintCommand}" CommandParameter="#E81123" />
                                            <MenuItem Header="Orange" Command="{Binding SetTintCommand}" CommandParameter="#F7630C" />
                                            <MenuItem Header="Green"  Command="{Binding SetTintCommand}" CommandParameter="#107C10" />
                                            <MenuItem Header="Blue"   Command="{Binding SetTintCommand}" CommandParameter="#0078D4" />
                                            <MenuItem Header="Purple" Command="{Binding SetTintCommand}" CommandParameter="#8764B8" />
                                        </MenuItem>
                                        <MenuItem Header="Clear tint" Command="{Binding ClearTintCommand}" />
                                        <Separator />
                                        <MenuItem Header="Close tab" Command="{Binding CloseCommand}" />
                                    </ContextMenu>
                                </Border.ContextMenu>
                            </Border>
                        </DataTemplate>
                    </ListBox.ItemTemplate>
                </ListBox>
            </Grid>
        </Border>

        <!-- Navigation Row -->
        <Border DockPanel.Dock="Top"
                IsVisible="{Binding ShowBrowserChrome}"
                Background="{DynamicResource HelixToolbarBrush}"
                Padding="8,6">
            <Grid ColumnDefinitions="Auto,*,Auto">
                <StackPanel Grid.Column="0" Orientation="Horizontal" Spacing="2">
                    <Button Classes="toolButton" ToolTip.Tip="Back"
                            Command="{Binding SelectedTab.ActivePane.GoBackCommand}"
                            Padding="6" Background="Transparent" BorderThickness="0" Cursor="Hand">
                        <PathIcon Data="{DynamicResource HelixIconArrowLeftGeometry}" Width="16" Height="16" />
                    </Button>
                    <Button ToolTip.Tip="Forward"
                            Command="{Binding SelectedTab.ActivePane.GoForwardCommand}"
                            Padding="6" Background="Transparent" BorderThickness="0" Cursor="Hand">
                        <PathIcon Data="{DynamicResource HelixIconArrowRightGeometry}" Width="16" Height="16" />
                    </Button>
                    <Button ToolTip.Tip="Up"
                            Command="{Binding SelectedTab.ActivePane.GoUpCommand}"
                            Padding="6" Background="Transparent" BorderThickness="0" Cursor="Hand">
                        <PathIcon Data="{DynamicResource HelixIconArrowUpGeometry}" Width="16" Height="16" />
                    </Button>
                    <Button ToolTip.Tip="Refresh"
                            Command="{Binding SelectedTab.ActivePane.RefreshCommand}"
                            Padding="6" Background="Transparent" BorderThickness="0" Cursor="Hand">
                        <PathIcon Data="{DynamicResource HelixIconArrowClockwiseGeometry}" Width="16" Height="16" />
                    </Button>
                </StackPanel>

                <Border Grid.Column="1"
                        Margin="8,0"
                        Background="{DynamicResource HelixContentCardBrush}"
                        CornerRadius="4"
                        Padding="4,2"
                        BorderBrush="{DynamicResource HelixBorderColor}"
                        BorderThickness="1"
                        MinHeight="28">
                    <Panel>
                        <StackPanel IsVisible="{Binding IsSettingsTab}"
                                    Orientation="Horizontal"
                                    Spacing="8"
                                    VerticalAlignment="Center"
                                    Margin="4,0">
                            <PathIcon Data="{DynamicResource HelixIconSettingsGeometry}"
                                      Width="16" Height="16" />
                            <TextBlock Text="Settings" FontSize="14" VerticalAlignment="Center" />
                        </StackPanel>
                        <Panel IsVisible="{Binding IsBrowserTab}">
                            <views:Omnibar DataContext="{Binding SelectedTab.ActivePane}" />
                        </Panel>
                    </Panel>
                </Border>

                <StackPanel Grid.Column="2" Orientation="Horizontal" Spacing="4">
                    <Button Classes="toolButton"
                            Command="{Binding FocusSearchCommand}"
                            ToolTip.Tip="Search (Ctrl+F)"
                            IsVisible="{Binding IsBrowserTab}"
                            Padding="8,4"
                            Cursor="Hand">
                        <PathIcon Data="{DynamicResource HelixIconSearchGeometry}" Width="16" Height="16" Opacity="0.7" />
                    </Button>
                    <Button ToolTip.Tip="Toggle theme (Ctrl+Shift+T)"
                            Command="{Binding ToggleThemeCommand}"
                            Padding="6" Background="Transparent" BorderThickness="0" Cursor="Hand">
                        <PathIcon Data="{DynamicResource HelixIconWeatherMoonGeometry}" Width="16" Height="16" />
                    </Button>
                </StackPanel>
            </Grid>
        </Border>

        <!-- Action Toolbar -->
        <Border DockPanel.Dock="Top"
                IsVisible="{Binding ShowFileToolbar}"
                Background="{DynamicResource HelixToolbarBrush}"
                Padding="8,4"
                BorderBrush="{DynamicResource HelixBorderColor}"
                BorderThickness="0,0,0,1">
            <Grid ColumnDefinitions="*,Auto">
                <StackPanel Grid.Column="0" Orientation="Horizontal" Spacing="2">
                    <Button ToolTip.Tip="New folder (Ctrl+Shift+N)"
                            Command="{Binding NewFolderCommand}"
                            Padding="6,4" Background="Transparent" BorderThickness="0" Cursor="Hand">
                        <StackPanel Orientation="Horizontal" Spacing="4">
                            <PathIcon Data="{DynamicResource HelixIconAddCircleGeometry}" Width="14" Height="14" />
                            <TextBlock Text="New" VerticalAlignment="Center" FontSize="12" />
                        </StackPanel>
                    </Button>
                    <Border Width="1" Background="{DynamicResource HelixBorderColor}" Margin="4,4" />
                    <Button ToolTip.Tip="Cut (Ctrl+X)"
                            Command="{Binding CutCommand}"
                            Padding="6" Background="Transparent" BorderThickness="0" Cursor="Hand">
                        <PathIcon Data="{DynamicResource HelixIconCutGeometry}" Width="14" Height="14"
                              Foreground="{DynamicResource HelixIconCutBrush}" />
                    </Button>
                    <Button ToolTip.Tip="Copy (Ctrl+C)"
                            Command="{Binding CopyCommand}"
                            Padding="6" Background="Transparent" BorderThickness="0" Cursor="Hand">
                        <PathIcon Data="{DynamicResource HelixIconCopyGeometry}" Width="14" Height="14"
                              Foreground="{DynamicResource HelixIconCopyBrush}" />
                    </Button>
                    <Button ToolTip.Tip="Paste (Ctrl+V)"
                            Command="{Binding PasteCommand}"
                            Padding="6" Background="Transparent" BorderThickness="0" Cursor="Hand">
                        <PathIcon Data="{DynamicResource HelixIconPasteGeometry}" Width="14" Height="14"
                              Foreground="{DynamicResource HelixIconPasteBrush}" />
                    </Button>
                    <Button ToolTip.Tip="Rename (F2)"
                            Command="{Binding RenameCommand}"
                            Padding="6" Background="Transparent" BorderThickness="0" Cursor="Hand">
                        <PathIcon Data="{DynamicResource HelixIconRenameGeometry}" Width="14" Height="14"
                              Foreground="{DynamicResource HelixIconRenameBrush}" />
                    </Button>
                    <Button ToolTip.Tip="Delete"
                            Command="{Binding DeleteCommand}"
                            Padding="6" Background="Transparent" BorderThickness="0" Cursor="Hand">
                        <PathIcon Data="{DynamicResource HelixIconDeleteGeometry}" Width="14" Height="14"
                              Foreground="{DynamicResource HelixIconDeleteBrush}" />
                    </Button>
                    <Border Width="1" Background="{DynamicResource HelixBorderColor}" Margin="4,4" />
                    <Button ToolTip.Tip="Sort"
                            Padding="6,4" Background="Transparent" BorderThickness="0" Cursor="Hand">
                        <StackPanel Orientation="Horizontal" Spacing="4">
                            <PathIcon Data="{DynamicResource HelixIconArrowSortGeometry}" Width="14" Height="14" />
                            <TextBlock Text="Sort" VerticalAlignment="Center" FontSize="12" />
                        </StackPanel>
                        <Button.Flyout>
                            <MenuFlyout>
                                <MenuItem Header="Name"
                                          ToggleType="Radio"
                                          IsChecked="{Binding IsSortByName}"
                                          Command="{Binding SetSortColumnCommand}"
                                          CommandParameter="{x:Static models:SortColumn.Name}" />
                                <MenuItem Header="Date"
                                          ToggleType="Radio"
                                          IsChecked="{Binding IsSortByDate}"
                                          Command="{Binding SetSortColumnCommand}"
                                          CommandParameter="{x:Static models:SortColumn.Modified}" />
                                <MenuItem Header="Type"
                                          ToggleType="Radio"
                                          IsChecked="{Binding IsSortByType}"
                                          Command="{Binding SetSortColumnCommand}"
                                          CommandParameter="{x:Static models:SortColumn.Type}" />
                                <MenuItem Header="Size"
                                          ToggleType="Radio"
                                          IsChecked="{Binding IsSortBySize}"
                                          Command="{Binding SetSortColumnCommand}"
                                          CommandParameter="{x:Static models:SortColumn.Size}" />
                                <Separator />
                                <MenuItem Header="Ascending"
                                          ToggleType="Radio"
                                          IsChecked="{Binding IsSortAscending}"
                                          Command="{Binding SetSortAscendingCommand}" />
                                <MenuItem Header="Descending"
                                          ToggleType="Radio"
                                          IsChecked="{Binding IsSortDescending}"
                                          Command="{Binding SetSortDescendingCommand}" />
                            </MenuFlyout>
                        </Button.Flyout>
                    </Button>
                    <Button ToolTip.Tip="Copy path (Ctrl+Shift+C)"
                            Command="{Binding CopyPathCommand}"
                            Padding="6" Background="Transparent" BorderThickness="0" Cursor="Hand">
                        <PathIcon Data="{DynamicResource HelixIconLinkGeometry}" Width="14" Height="14"
                              Foreground="{DynamicResource HelixIconCopyBrush}" />
                    </Button>
                </StackPanel>
                <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="2">
                    <Button ToolTip.Tip="View options"
                            Padding="6" Background="Transparent" BorderThickness="0" Cursor="Hand">
                        <PathIcon Data="{DynamicResource HelixIconTextBulletListGeometry}"
                                  Width="14" Height="14" />
                        <Button.Flyout>
                            <MenuFlyout>
                                <MenuItem Header="Hidden items"
                                          ToggleType="CheckBox"
                                          IsChecked="{Binding ShowHiddenFiles, Mode=TwoWay}" />
                                <MenuItem Header="File name extensions"
                                          ToggleType="CheckBox"
                                          IsChecked="{Binding ShowFileExtensions, Mode=TwoWay}" />
                            </MenuFlyout>
                        </Button.Flyout>
                    </Button>
                    <Border Width="1" Background="{DynamicResource HelixBorderColor}" Margin="4,4" />
                    <Button ToolTip.Tip="Details view"
                            Command="{Binding SetViewModeCommand}"
                            CommandParameter="{x:Static models:LayoutMode.Details}"
                            Padding="6" Background="Transparent" BorderThickness="0" Cursor="Hand">
                        <PathIcon Data="{DynamicResource HelixIconTextBulletListGeometry}" Width="14" Height="14" />
                    </Button>
                    <Button ToolTip.Tip="List view"
                            Command="{Binding SetViewModeCommand}"
                            CommandParameter="{x:Static models:LayoutMode.List}"
                            Padding="6" Background="Transparent" BorderThickness="0" Cursor="Hand">
                        <PathIcon Data="{DynamicResource HelixIconListGeometry}" Width="14" Height="14" />
                    </Button>
                    <Button ToolTip.Tip="Grid view"
                            Command="{Binding SetViewModeCommand}"
                            CommandParameter="{x:Static models:LayoutMode.Grid}"
                            Padding="6" Background="Transparent" BorderThickness="0" Cursor="Hand">
                        <PathIcon Data="{DynamicResource HelixIconGridGeometry}" Width="14" Height="14" />
                    </Button>
                    <Button ToolTip.Tip="Miller columns"
                            Command="{Binding SetViewModeCommand}"
                            CommandParameter="{x:Static models:LayoutMode.Miller}"
                            Padding="6" Background="Transparent" BorderThickness="0" Cursor="Hand">
                        <PathIcon Data="{DynamicResource HelixIconLayoutColumnThreeGeometry}" Width="14" Height="14" />
                    </Button>
                    <Border Width="1" Background="{DynamicResource HelixBorderColor}" Margin="4,4" />
                    <Button ToolTip.Tip="Dual pane (Ctrl+D)"
                            Command="{Binding ToggleDualPaneCommand}"
                            Padding="6" Background="Transparent" BorderThickness="0" Cursor="Hand">
                        <PathIcon Data="{DynamicResource HelixIconPanelLeftGeometry}" Width="14" Height="14" />
                    </Button>
                    <Button ToolTip.Tip="Swap panes"
                            Command="{Binding SelectedTab.SwapPanesCommand}"
                            Padding="6" Background="Transparent" BorderThickness="0" Cursor="Hand"
                            IsVisible="{Binding SelectedTab.IsDualPane}">
                        <PathIcon Data="{DynamicResource HelixIconArrowSwapGeometry}" Width="14" Height="14" />
                    </Button>
                    <Button ToolTip.Tip="Flip split orientation"
                            Command="{Binding SelectedTab.FlipOrientationCommand}"
                            Padding="6" Background="Transparent" BorderThickness="0" Cursor="Hand"
                            IsVisible="{Binding SelectedTab.IsDualPane}">
                        <PathIcon Data="{DynamicResource HelixIconArrowAutofitHeightGeometry}" Width="14" Height="14" />
                    </Button>
                </StackPanel>
            </Grid>
        </Border>

        <!-- Status Bar -->
        <Border DockPanel.Dock="Bottom"
                Background="{DynamicResource HelixStatusBarBrush}"
                Padding="12,4"
                BorderBrush="{DynamicResource HelixBorderColor}"
                BorderThickness="0,1,0,0"
                Height="32">
            <Grid ColumnDefinitions="Auto,*,Auto">
                <Button Grid.Column="0"
                        x:Name="BranchButton"
                        Click="OnBranchButtonClick"
                        Padding="6,2"
                        Background="Transparent"
                        BorderThickness="0"
                        Cursor="Hand"
                        IsVisible="{Binding SelectedTab.ActivePane.RepositoryStatus.IsRepository, FallbackValue=False}"
                        ToolTip.Tip="Switch branch">
                    <TextBlock Text="{Binding SelectedTab.ActivePane.RepositoryStatus.Display}"
                               Foreground="{DynamicResource HelixAccentBrush}"
                               FontSize="12"
                               VerticalAlignment="Center" />
                    <FlyoutBase.AttachedFlyout>
                        <Flyout Placement="TopEdgeAlignedLeft">
                            <ListBox x:Name="BranchList"
                                     ItemsSource="{Binding SelectedTab.ActivePane.Branches}"
                                     DoubleTapped="OnBranchSelected"
                                     Width="240"
                                     MaxHeight="260" />
                        </Flyout>
                    </FlyoutBase.AttachedFlyout>
                </Button>
                <TextBlock Grid.Column="1"
                           Text="{Binding SelectedTab.ActivePane.StatusText}"
                           VerticalAlignment="Center"
                           FontSize="12"
                           Opacity="0.7"
                           Margin="12,0,0,0" />
                <StackPanel Grid.Column="2" Orientation="Horizontal" Spacing="8">
                    <TextBlock Text="{Binding SelectedTab.ActivePane.SelectedCount, StringFormat='{}{0} selected'}"
                               VerticalAlignment="Center" FontSize="12" Opacity="0.7"
                               IsVisible="{Binding ShowFileToolbar}" />
                    <Button Classes="toolButton"
                            Command="{Binding ToggleStatusCentreCommand}"
                            ToolTip.Tip="Status centre"
                            Padding="6,2"
                            Cursor="Hand">
                        <PathIcon Data="{DynamicResource HelixIconInfoGeometry}"
                                  Width="14" Height="14" />
                    </Button>
                </StackPanel>
            </Grid>
        </Border>

        <DockPanel>
                <Border DockPanel.Dock="Top"
                        IsVisible="{Binding IsDiscoveringNetwork}"
                        Background="{DynamicResource HelixToolbarBrush}"
                        BorderBrush="{DynamicResource HelixBorderColor}"
                        BorderThickness="0,0,0,1"
                        Padding="12,8">
                    <StackPanel Orientation="Horizontal" Spacing="10">
                        <PathIcon Data="{DynamicResource HelixIconGlobeDesktopGeometry}"
                                  Width="14" Height="14"
                                  Foreground="{DynamicResource HelixAccentBrush}" />
                        <TextBlock Text="{Binding NetworkBannerText}"
                                   VerticalAlignment="Center"
                                   FontSize="12"
                                   Opacity="0.85" />
                    </StackPanel>
                </Border>

                <views:DualPaneView DataContext="{Binding SelectedTab}" />
        </DockPanel>

            </DockPanel>
        </Grid>

        <views:CommandPaletteOverlay IsVisible="{Binding IsCommandPaletteOpen}"
                                      IsHitTestVisible="{Binding IsCommandPaletteOpen}"
                                      DataContext="{Binding}" />
        <views:StatusCentreFlyout DataContext="{Binding}" />
    </Grid>
</Window>
