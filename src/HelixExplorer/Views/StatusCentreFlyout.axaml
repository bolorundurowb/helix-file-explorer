<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:HelixExplorer.ViewModels"
             xmlns:services="using:HelixExplorer.Services"
             x:Class="HelixExplorer.Views.StatusCentreFlyout"
             x:DataType="vm:MainWindowViewModel"
             IsVisible="{Binding IsStatusCentreOpen}"
             IsHitTestVisible="{Binding IsStatusCentreOpen}"
             VerticalAlignment="Bottom"
             HorizontalAlignment="Right"
             Margin="0,0,16,40">
    <Border Background="{DynamicResource HelixContentCardBrush}"
            BorderBrush="{DynamicResource HelixBorderColor}"
            BorderThickness="1"
            CornerRadius="8"
            Padding="16,12"
            MinWidth="320"
            MaxWidth="420"
            MaxHeight="360"
            BoxShadow="0 8 24 0 #40000000">
        <Grid RowDefinitions="Auto,Auto,*,Auto" DataContext="{Binding OperationReporter}">
            <TextBlock Grid.Row="0"
                       Text="Status centre"
                       FontWeight="SemiBold"
                       FontSize="14"
                       Margin="0,0,0,12" />

            <Border Grid.Row="1"
                    IsVisible="{Binding HasActive}"
                    Background="{DynamicResource HelixToolbarBrush}"
                    CornerRadius="6"
                    Padding="12,10"
                    Margin="0,0,0,12">
                <StackPanel Spacing="8">
                    <TextBlock Text="{Binding ActiveTitle}"
                               FontWeight="SemiBold"
                               FontSize="12" />
                    <ProgressBar Minimum="0"
                                 Maximum="1"
                                 Value="{Binding Progress}"
                                 IsIndeterminate="{Binding IsIndeterminate}"
                                 Height="4" />
                    <TextBlock Text="{Binding ActiveDetail}"
                               FontSize="11"
                               Opacity="0.65"
                               TextTrimming="CharacterEllipsis"
                               IsVisible="{Binding HasActiveDetail}" />
                </StackPanel>
            </Border>

            <ScrollViewer Grid.Row="2"
                          VerticalScrollBarVisibility="Auto"
                          IsVisible="{Binding HasCompleted}">
                <ItemsControl ItemsSource="{Binding Completed}">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate x:DataType="services:OperationEntry">
                            <Grid ColumnDefinitions="Auto,*,Auto"
                                  Margin="0,4">
                                <!-- Success: green check / Failure: warning glyph -->
                                <PathIcon Grid.Column="0"
                                          Width="16" Height="16"
                                          Margin="0,0,8,0"
                                          VerticalAlignment="Center"
                                          Data="{DynamicResource HelixIconCheckmarkGeometry}"
                                          Foreground="#107C10"
                                          IsVisible="{Binding Succeeded}" />
                                <PathIcon Grid.Column="0"
                                          Width="16" Height="16"
                                          Margin="0,0,8,0"
                                          VerticalAlignment="Center"
                                          Data="{DynamicResource HelixIconInfoGeometry}"
                                          Foreground="#D13438"
                                          IsVisible="{Binding Failed}" />
                                <TextBlock Grid.Column="1"
                                           Text="{Binding Message}"
                                           FontSize="12"
                                           VerticalAlignment="Center"
                                           TextTrimming="CharacterEllipsis"
                                           Foreground="{Binding Failed, Converter={StaticResource BoolToFailureBrushConverter}, FallbackValue=#D13438}" />
                            </Grid>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </ScrollViewer>

            <StackPanel Grid.Row="3"
                        Orientation="Horizontal"
                        HorizontalAlignment="Right"
                        Spacing="8"
                        Margin="0,12,0,0">
                <Button Content="Clear"
                        Command="{Binding ClearCompletedCommand}"
                        Classes="toolButton"
                        Padding="10,6" />
                <Button Content="Close"
                        Click="OnCloseClick"
                        Classes="toolButton"
                        Padding="10,6" />
            </StackPanel>
        </Grid>
    </Border>
</UserControl>