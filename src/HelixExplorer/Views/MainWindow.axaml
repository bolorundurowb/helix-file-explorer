<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="using:HelixExplorer.ViewModels"
        xmlns:views="using:HelixExplorer.Views"
        xmlns:models="using:HelixExplorer.Core.Models"
        x:Class="HelixExplorer.Views.MainWindow"
        x:DataType="vm:MainWindowViewModel"
        Title="{Binding Title}"
        Width="1280" Height="800"
        MinWidth="800" MinHeight="500"
        WindowStartupLocation="CenterScreen"
        ExtendClientAreaToDecorationsHint="True"
        ExtendClientAreaTitleBarHeightHint="40"
        WindowDecorations="Full"
        Background="{DynamicResource HelixChromeBrush}">

    <Window.Styles>
        <Style Selector="WindowDrawnDecorations /template/ Panel#PART_TitleTextPanel > TextBlock">
            <Setter Property="IsVisible" Value="False" />
        </Style>
    </Window.Styles>

    <Window.KeyBindings>
        <KeyBinding Gesture="Ctrl+Shift+P" Command="{Binding ToggleCommandPaletteCommand}" />
        <KeyBinding Gesture="Ctrl+B" Command="{Binding ToggleSidebarCommand}" />
        <KeyBinding Gesture="Ctrl+Shift+T" Command="{Binding ToggleThemeCommand}" />
        <KeyBinding Gesture="Ctrl+T" Command="{Binding NewTabCommand}" />
        <KeyBinding Gesture="Ctrl+W" Command="{Binding CloseSelectedTabCommand}" />
        <KeyBinding Gesture="Ctrl+D" Command="{Binding ToggleDualPaneCommand}" />
        <KeyBinding Gesture="Ctrl+F" Command="{Binding ToggleFilterCommand}" />
        <KeyBinding Gesture="Ctrl+X" Command="{Binding CutCommand}" />
        <KeyBinding Gesture="Ctrl+C" Command="{Binding CopyCommand}" />
        <KeyBinding Gesture="Ctrl+V" Command="{Binding PasteCommand}" />
        <KeyBinding Gesture="Delete" Command="{Binding DeleteCommand}" />
        <KeyBinding Gesture="F2" Command="{Binding RenameCommand}" />
        <KeyBinding Gesture="Ctrl+Shift+N" Command="{Binding NewFolderCommand}" />
        <KeyBinding Gesture="Ctrl+A" Command="{Binding SelectAllCommand}" />
    </Window.KeyBindings>

    <DockPanel LastChildFill="True">

        <!-- Tab Strip -->
        <Border DockPanel.Dock="Top"
                Background="{DynamicResource HelixTabStripBrush}"
                Padding="8,4,140,0"
                Height="40"
                WindowDecorationProperties.ElementRole="User">
            <Grid ColumnDefinitions="*,Auto,12">
                <ListBox x:Name="TabStrip"
                         Grid.Column="0"
                         ItemsSource="{Binding Tabs}"
                         SelectedItem="{Binding SelectedTab, Mode=TwoWay}"
                         Background="Transparent"
                         BorderThickness="0"
                         Padding="0"
                         PointerWheelChanged="OnTabStripWheel"
                         ScrollViewer.VerticalScrollBarVisibility="Disabled"
                         ScrollViewer.HorizontalScrollBarVisibility="Auto">
                    <ListBox.ItemsPanel>
                        <ItemsPanelTemplate>
                            <StackPanel Orientation="Horizontal" Spacing="2" />
                        </ItemsPanelTemplate>
                    </ListBox.ItemsPanel>
                    <ListBox.Styles>
                        <Style Selector="ListBoxItem">
                            <Setter Property="Padding" Value="0" />
                            <Setter Property="Margin" Value="0" />
                            <Setter Property="Background" Value="Transparent" />
                            <Setter Property="VerticalAlignment" Value="Bottom" />
                        </Style>
                        <Style Selector="ListBoxItem:selected /template/ ContentPresenter">
                            <Setter Property="Background" Value="Transparent" />
                        </Style>
                        <Style Selector="ListBoxItem:selected Border#TabChip">
                            <Setter Property="Background" Value="{DynamicResource HelixContentCardBrush}" />
                        </Style>
                    </ListBox.Styles>
                    <ListBox.ItemTemplate>
                        <DataTemplate x:DataType="vm:TabViewModel">
                            <Border x:Name="TabChip"
                                    CornerRadius="8,8,0,0"
                                    Background="Transparent"
                                    Padding="12,6"
                                    MinWidth="150" MaxWidth="220"
                                    PointerReleased="OnTabPointerReleased"
                                    WindowDecorationProperties.ElementRole="User">
                                <Grid RowDefinitions="*,Auto">
                                    <StackPanel Grid.Row="0" Orientation="Horizontal" Spacing="8">
                                        <PathIcon Data="M10,4H4C2.89,4 2,4.89 2,6V18A2,2 0 0,0 4,20H20A2,2 0 0,0 22,18V8C22,6.89 21.1,6 20,6H12L10,4Z"
                                                  Width="14" Height="14"
                                                  Foreground="{DynamicResource HelixAccentBrush}" />
                                        <TextBlock Text="{Binding Title}"
                                                   VerticalAlignment="Center"
                                                   TextTrimming="CharacterEllipsis"
                                                   MaxWidth="140" />
                                        <Button Command="{Binding CloseCommand}"
                                                Padding="2" Background="Transparent" BorderThickness="0"
                                                FontSize="12" Opacity="0.6" Cursor="Hand"
                                                ToolTip.Tip="Close tab (Ctrl+W)"
                                                WindowDecorationProperties.ElementRole="User">
                                            <TextBlock Text="✕" />
                                        </Button>
                                    </StackPanel>
                                    <Border Grid.Row="1"
                                            Height="3"
                                            CornerRadius="2"
                                            Margin="0,4,0,0"
                                            Background="{Binding TintBrush}"
                                            IsVisible="{Binding HasTint}" />
                                </Grid>
                                <Border.ContextMenu>
                                    <ContextMenu>
                                        <MenuItem Header="Tint">
                                            <MenuItem Header="Red"    Command="{Binding SetTintCommand}" CommandParameter="#E81123" />
                                            <MenuItem Header="Orange" Command="{Binding SetTintCommand}" CommandParameter="#F7630C" />
                                            <MenuItem Header="Green"  Command="{Binding SetTintCommand}" CommandParameter="#107C10" />
                                            <MenuItem Header="Blue"   Command="{Binding SetTintCommand}" CommandParameter="#0078D4" />
                                            <MenuItem Header="Purple" Command="{Binding SetTintCommand}" CommandParameter="#8764B8" />
                                        </MenuItem>
                                        <MenuItem Header="Clear tint" Command="{Binding ClearTintCommand}" />
                                        <Separator />
                                        <MenuItem Header="Close tab" Command="{Binding CloseCommand}" />
                                    </ContextMenu>
                                </Border.ContextMenu>
                            </Border>
                        </DataTemplate>
                    </ListBox.ItemTemplate>
                </ListBox>

                <Border Grid.Column="2"
                        Background="Transparent"
                        WindowDecorationProperties.ElementRole="TitleBar" />

                <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="4" VerticalAlignment="Center"
                            WindowDecorationProperties.ElementRole="User">
                    <Button Command="{Binding NewTabCommand}"
                            Content="+" Padding="8,2" Background="Transparent" BorderThickness="0"
                            FontSize="18" Opacity="0.7" Cursor="Hand" ToolTip.Tip="New Tab (Ctrl+T)"
                            WindowDecorationProperties.ElementRole="User" />
                    <Button Command="{Binding ToggleDualPaneCommand}"
                            ToolTip.Tip="Dual Pane (Ctrl+D)" Padding="6" Background="Transparent" BorderThickness="0" Cursor="Hand"
                            WindowDecorationProperties.ElementRole="User">
                        <PathIcon Data="M3,3H11V21H3V3M13,3H21V21H13V3M5,5V19H9V5H5M15,5V19H19V5H15Z" Width="16" Height="16" />
                    </Button>
                </StackPanel>
            </Grid>
        </Border>

        <!-- Navigation Row -->
        <Border DockPanel.Dock="Top"
                Background="{DynamicResource HelixToolbarBrush}"
                Padding="8,6">
            <Grid ColumnDefinitions="Auto,*,Auto">
                <StackPanel Grid.Column="0" Orientation="Horizontal" Spacing="2">
                    <Button ToolTip.Tip="Back"
                            Command="{Binding SelectedTab.ActivePane.GoBackCommand}"
                            Padding="6" Background="Transparent" BorderThickness="0" Cursor="Hand">
                        <PathIcon Data="M20,11H7.83L13.42,5.41L12,4L4,12L12,20L13.41,18.59L7.83,13H20V11Z" Width="16" Height="16" />
                    </Button>
                    <Button ToolTip.Tip="Forward"
                            Command="{Binding SelectedTab.ActivePane.GoForwardCommand}"
                            Padding="6" Background="Transparent" BorderThickness="0" Cursor="Hand">
                        <PathIcon Data="M4,11V13H16.17L10.58,18.59L12,20L20,12L12,4L10.59,5.41L16.17,11H4Z" Width="16" Height="16" />
                    </Button>
                    <Button ToolTip.Tip="Up"
                            Command="{Binding SelectedTab.ActivePane.GoUpCommand}"
                            Padding="6" Background="Transparent" BorderThickness="0" Cursor="Hand">
                        <PathIcon Data="M13,20H11V8L5.5,13.5L4.08,12.08L12,4.16L19.92,12.08L18.5,13.5L13,8V20Z" Width="16" Height="16" />
                    </Button>
                    <Button ToolTip.Tip="Refresh"
                            Command="{Binding SelectedTab.ActivePane.RefreshCommand}"
                            Padding="6" Background="Transparent" BorderThickness="0" Cursor="Hand">
                        <PathIcon Data="M17.65,6.35C16.2,4.9 14.21,4 12,4A8,8 0 0,0 4,12A8,8 0 0,0 12,20C15.73,20 18.84,17.45 19.73,14H17.65C16.83,16.33 14.61,18 12,18A6,6 0 0,1 6,12A6,6 0 0,1 12,6C13.66,6 15.14,6.69 16.22,7.78L13,11H20V4L17.65,6.35Z" Width="16" Height="16" />
                    </Button>
                </StackPanel>

                <Border Grid.Column="1"
                        Margin="8,0"
                        Background="{DynamicResource HelixContentCardBrush}"
                        CornerRadius="4"
                        Padding="4,2"
                        BorderBrush="{DynamicResource HelixBorderColor}"
                        BorderThickness="1"
                        MinHeight="28">
                    <views:Omnibar DataContext="{Binding SelectedTab.ActivePane}" />
                </Border>

                <StackPanel Grid.Column="2" Orientation="Horizontal" Spacing="4">
                    <Button Command="{Binding ToggleFilterCommand}"
                            ToolTip.Tip="Filter items (Ctrl+F)"
                            Background="{DynamicResource HelixContentCardBrush}"
                            BorderBrush="{DynamicResource HelixBorderColor}"
                            BorderThickness="1"
                            Padding="8,4"
                            Cursor="Hand">
                        <StackPanel Orientation="Horizontal" Spacing="6">
                            <PathIcon Data="M9.5,3A6.5,6.5 0 0,1 16,9.5C16,11.11 15.41,12.59 14.44,13.73L14.71,14H15.5L20.5,19L19,20.5L14,15.5V14.71L13.73,14.44C12.59,15.41 11.11,16 9.5,16A6.5,6.5 0 0,1 3,9.5A6.5,6.5 0 0,1 9.5,3M9.5,5C7,5 5,7 5,9.5C5,12 7,14 9.5,14C12,14 14,12 14,9.5C14,7 12,5 9.5,5Z" Width="14" Height="14" Opacity="0.6" />
                            <TextBlock Text="Search" VerticalAlignment="Center" Opacity="0.7" />
                        </StackPanel>
                    </Button>
                    <Button ToolTip.Tip="Toggle theme (Ctrl+Shift+T)"
                            Command="{Binding ToggleThemeCommand}"
                            Padding="6" Background="Transparent" BorderThickness="0" Cursor="Hand">
                        <PathIcon Data="M12,18C11.11,18 10.26,17.8 9.5,17.45C11.56,16.5 13,14.42 13,12C13,9.58 11.56,7.5 9.5,6.55C10.26,6.2 11.11,6 12,6A6,6 0 0,1 18,12A6,6 0 0,1 12,18M20,8.69V4H15.31L12,0.69L8.69,4H4V8.69L0.69,12L4,15.31V20H8.69L12,23.31L15.31,20H20V15.31L23.31,12L20,8.69Z" Width="16" Height="16" />
                    </Button>
                    <Button ToolTip.Tip="Toggle sidebar (Ctrl+B)"
                            Command="{Binding ToggleSidebarCommand}"
                            Padding="6" Background="Transparent" BorderThickness="0" Cursor="Hand">
                        <PathIcon Data="M3,3H21V21H3V3M5,5V19H9V5H5Z" Width="16" Height="16" />
                    </Button>
                </StackPanel>
            </Grid>
        </Border>

        <!-- Action Toolbar -->
        <Border DockPanel.Dock="Top"
                Background="{DynamicResource HelixToolbarBrush}"
                Padding="8,4"
                BorderBrush="{DynamicResource HelixBorderColor}"
                BorderThickness="0,0,0,1">
            <Grid ColumnDefinitions="*,Auto">
                <StackPanel Grid.Column="0" Orientation="Horizontal" Spacing="2">
                    <Button ToolTip.Tip="New folder (Ctrl+Shift+N)"
                            Command="{Binding NewFolderCommand}"
                            Padding="6,4" Background="Transparent" BorderThickness="0" Cursor="Hand">
                        <StackPanel Orientation="Horizontal" Spacing="4">
                            <PathIcon Data="M19,13H13V19H11V13H5V11H11V5H13V11H19V13Z" Width="14" Height="14" />
                            <TextBlock Text="New" VerticalAlignment="Center" FontSize="12" />
                        </StackPanel>
                    </Button>
                    <Border Width="1" Background="{DynamicResource HelixBorderColor}" Margin="4,4" />
                    <Button ToolTip.Tip="Cut (Ctrl+X)"
                            Command="{Binding CutCommand}"
                            Padding="6" Background="Transparent" BorderThickness="0" Cursor="Hand">
                        <PathIcon Data="M19,3L13,9L15,11L22,4V3M12,12.5A0.5,0.5 0 0,1 11.5,12A0.5,0.5 0 0,1 12,11.5A0.5,0.5 0 0,1 12.5,12A0.5,0.5 0 0,1 12,12.5M6,20A2,2 0 0,1 4,18C4,16.89 4.9,16 6,16A2,2 0 0,1 8,18C8,19.11 7.1,20 6,20M6,8A2,2 0 0,1 4,6C4,4.89 4.9,4 6,4A2,2 0 0,1 8,6C8,7.11 7.1,8 6,8M9.64,7.64C9.87,7.14 10,6.59 10,6A4,4 0 0,0 6,2A4,4 0 0,0 2,6A4,4 0 0,0 6,10C6.59,10 7.14,9.87 7.64,9.64L10,12L7.64,14.36C7.14,14.13 6.59,14 6,14A4,4 0 0,0 2,18A4,4 0 0,0 6,22A4,4 0 0,0 10,18C10,17.41 9.87,16.86 9.64,16.36L12,14L19,21H22V20L9.64,7.64Z" Width="14" Height="14" />
                    </Button>
                    <Button ToolTip.Tip="Copy (Ctrl+C)"
                            Command="{Binding CopyCommand}"
                            Padding="6" Background="Transparent" BorderThickness="0" Cursor="Hand">
                        <PathIcon Data="M19,21H8V7H19M19,5H8A2,2 0 0,0 6,7V21A2,2 0 0,0 8,23H19A2,2 0 0,0 21,21V7A2,2 0 0,0 19,5M16,1H4A2,2 0 0,0 2,3V17H4V3H16V1Z" Width="14" Height="14" />
                    </Button>
                    <Button ToolTip.Tip="Paste (Ctrl+V)"
                            Command="{Binding PasteCommand}"
                            Padding="6" Background="Transparent" BorderThickness="0" Cursor="Hand">
                        <PathIcon Data="M19,20H5V4H7V7H17V4H19M12,2A1,1 0 0,1 13,3A1,1 0 0,1 12,4A1,1 0 0,1 11,3A1,1 0 0,1 12,2M19,2H14.82C14.4,0.84 13.3,0 12,0C10.7,0 9.6,0.84 9.18,2H5A2,2 0 0,0 3,4V20A2,2 0 0,0 5,22H19A2,2 0 0,0 21,20V4A2,2 0 0,0 19,2Z" Width="14" Height="14" />
                    </Button>
                    <Button ToolTip.Tip="Rename (F2)"
                            Command="{Binding RenameCommand}"
                            Padding="6" Background="Transparent" BorderThickness="0" Cursor="Hand">
                        <PathIcon Data="M20.71,7.04C21.1,6.65 21.1,6 20.71,5.63L18.37,3.29C18,2.9 17.35,2.9 16.96,3.29L15.12,5.12L18.87,8.87M3,17.25V21H6.75L17.81,9.93L14.06,6.18L3,17.25Z" Width="14" Height="14" />
                    </Button>
                    <Button ToolTip.Tip="Delete"
                            Command="{Binding DeleteCommand}"
                            Padding="6" Background="Transparent" BorderThickness="0" Cursor="Hand">
                        <PathIcon Data="M19,4H15.5L14.5,3H9.5L8.5,4H5V6H19M6,19A2,2 0 0,0 8,21H16A2,2 0 0,0 18,19V7H6V19Z" Width="14" Height="14" />
                    </Button>
                </StackPanel>
                <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="2">
                    <Button ToolTip.Tip="Details view"
                            Command="{Binding SetViewModeCommand}"
                            CommandParameter="{x:Static models:LayoutMode.Details}"
                            Padding="6" Background="Transparent" BorderThickness="0" Cursor="Hand">
                        <PathIcon Data="M3,5H21V7H3V5M3,11H21V13H3V11M3,17H21V19H3V17Z" Width="14" Height="14" />
                    </Button>
                    <Button ToolTip.Tip="List view"
                            Command="{Binding SetViewModeCommand}"
                            CommandParameter="{x:Static models:LayoutMode.List}"
                            Padding="6" Background="Transparent" BorderThickness="0" Cursor="Hand">
                        <PathIcon Data="M7,5H21V7H7V5M7,13V11H21V13H7M4,4.5A1.5,1.5 0 0,1 5.5,6A1.5,1.5 0 0,1 4,7.5A1.5,1.5 0 0,1 2.5,6A1.5,1.5 0 0,1 4,4.5M4,10.5A1.5,1.5 0 0,1 5.5,12A1.5,1.5 0 0,1 4,13.5A1.5,1.5 0 0,1 2.5,12A1.5,1.5 0 0,1 4,10.5M7,19V17H21V19H7M4,16.5A1.5,1.5 0 0,1 5.5,18A1.5,1.5 0 0,1 4,19.5A1.5,1.5 0 0,1 2.5,18A1.5,1.5 0 0,1 4,16.5Z" Width="14" Height="14" />
                    </Button>
                    <Button ToolTip.Tip="Grid view"
                            Command="{Binding SetViewModeCommand}"
                            CommandParameter="{x:Static models:LayoutMode.Grid}"
                            Padding="6" Background="Transparent" BorderThickness="0" Cursor="Hand">
                        <PathIcon Data="M3,3H9V9H3V3M3,13H9V19H3V13M13,3H19V9H13V3M13,13H19V19H13V13Z" Width="14" Height="14" />
                    </Button>
                    <Button ToolTip.Tip="Miller columns"
                            Command="{Binding SetViewModeCommand}"
                            CommandParameter="{x:Static models:LayoutMode.Miller}"
                            Padding="6" Background="Transparent" BorderThickness="0" Cursor="Hand">
                        <PathIcon Data="M3,5H11V19H3V5M13,5H21V11H13V5M13,13H21V19H13V13Z" Width="14" Height="14" />
                    </Button>
                    <Border Width="1" Background="{DynamicResource HelixBorderColor}" Margin="4,4" />
                    <Button ToolTip.Tip="Swap panes"
                            Command="{Binding SelectedTab.SwapPanesCommand}"
                            Padding="6" Background="Transparent" BorderThickness="0" Cursor="Hand">
                        <PathIcon Data="M6.45,17.45L1,12L6.45,6.55L7.86,7.96L4.83,11H15V13H4.83L7.86,16.04L6.45,17.45M17.55,6.55L23,12L17.55,17.45L16.14,16.04L19.17,13H9V11H19.17L16.14,7.96L17.55,6.55Z" Width="14" Height="14" />
                    </Button>
                    <Button ToolTip.Tip="Flip split orientation"
                            Command="{Binding SelectedTab.FlipOrientationCommand}"
                            Padding="6" Background="Transparent" BorderThickness="0" Cursor="Hand">
                        <PathIcon Data="M15,21H17V19H15M19,9H21V7H19M3,5V19A2,2 0 0,0 5,21H9V19H5V5H9V3H5A2,2 0 0,0 3,5M19,3V5H21A2,2 0 0,0 19,3M11,23H13V1H11M19,17H21V15H19M15,5H17V3H15M19,13H21V11H19M19,21A2,2 0 0,0 21,19H19Z" Width="14" Height="14" />
                    </Button>
                </StackPanel>
            </Grid>
        </Border>

        <!-- Status Bar -->
        <Border DockPanel.Dock="Bottom"
                Background="{DynamicResource HelixStatusBarBrush}"
                Padding="12,4"
                BorderBrush="{DynamicResource HelixBorderColor}"
                BorderThickness="0,1,0,0"
                Height="32">
            <Grid ColumnDefinitions="Auto,*,Auto">
                <Button Grid.Column="0"
                        x:Name="BranchButton"
                        Click="OnBranchButtonClick"
                        Padding="6,2"
                        Background="Transparent"
                        BorderThickness="0"
                        Cursor="Hand"
                        IsVisible="{Binding SelectedTab.ActivePane.RepositoryStatus.IsRepository, FallbackValue=False}"
                        ToolTip.Tip="Switch branch">
                    <TextBlock Text="{Binding SelectedTab.ActivePane.RepositoryStatus.Display}"
                               Foreground="{DynamicResource HelixAccentBrush}"
                               FontSize="12"
                               VerticalAlignment="Center" />
                    <FlyoutBase.AttachedFlyout>
                        <Flyout Placement="TopEdgeAlignedLeft">
                            <ListBox x:Name="BranchList"
                                     ItemsSource="{Binding SelectedTab.ActivePane.Branches}"
                                     DoubleTapped="OnBranchSelected"
                                     Width="240"
                                     MaxHeight="260" />
                        </Flyout>
                    </FlyoutBase.AttachedFlyout>
                </Button>
                <TextBlock Grid.Column="1"
                           Text="{Binding SelectedTab.ActivePane.StatusText}"
                           VerticalAlignment="Center"
                           FontSize="12"
                           Opacity="0.7"
                           Margin="12,0,0,0" />
                <TextBlock Grid.Column="2"
                           Text="{Binding SelectedTab.ActivePane.SelectedCount, StringFormat='{}{0} selected'}"
                           VerticalAlignment="Center" FontSize="12" Opacity="0.7" />
            </Grid>
        </Border>

        <!-- Main Content: Sidebar + Content Card -->
        <Grid ColumnDefinitions="Auto,*">
            <Border Grid.Column="0"
                    Background="{DynamicResource HelixSidebarBrush}"
                    Width="{DynamicResource HelixSidebarDefaultWidth}"
                    IsVisible="{Binding IsSidebarOpen}"
                    BorderBrush="{DynamicResource HelixBorderColor}"
                    BorderThickness="0,0,1,0">
                <DockPanel>
                    <Border DockPanel.Dock="Bottom"
                            Padding="12,8"
                            BorderBrush="{DynamicResource HelixBorderColor}"
                            BorderThickness="0,1,0,0"
                            Cursor="Hand">
                        <StackPanel Orientation="Horizontal" Spacing="10">
                            <PathIcon Data="M12,15.5A3.5,3.5 0 0,1 8.5,12A3.5,3.5 0 0,1 12,8.5A3.5,3.5 0 0,1 15.5,12A3.5,3.5 0 0,1 12,15.5M19.43,12.97C19.47,12.65 19.5,12.33 19.5,12C19.5,11.67 19.47,11.34 19.43,11L21.54,9.37C21.73,9.22 21.78,8.95 21.66,8.73L19.66,5.27C19.54,5.05 19.27,4.96 19.05,5.05L16.56,6.05C16.04,5.66 15.5,5.32 14.87,5.07L14.5,2.42C14.46,2.18 14.25,2 14,2H10C9.75,2 9.54,2.18 9.5,2.42L9.13,5.07C8.5,5.32 7.96,5.66 7.44,6.05L4.95,5.05C4.73,4.96 4.46,5.05 4.34,5.27L2.34,8.73C2.21,8.95 2.27,9.22 2.46,9.37L4.57,11C4.53,11.34 4.5,11.67 4.5,12C4.5,12.33 4.53,12.65 4.57,12.97L2.46,14.63C2.27,14.78 2.21,15.05 2.34,15.27L4.34,18.73C4.46,18.95 4.73,19.04 4.95,18.95L7.44,17.94C7.96,18.34 8.5,18.68 9.13,18.93L9.5,21.58C9.54,21.82 9.75,22 10,22H14C14.25,22 14.46,21.82 14.5,21.58L14.87,18.93C15.5,18.67 16.04,18.34 16.56,17.94L19.05,18.95C19.27,19.04 19.54,18.95 19.66,18.73L21.66,15.27C21.78,15.05 21.73,14.78 21.54,14.63L19.43,12.97Z" Width="16" Height="16" />
                            <TextBlock Text="Settings" VerticalAlignment="Center" />
                        </StackPanel>
                    </Border>

                    <ScrollViewer VerticalScrollBarVisibility="Auto">
                        <ItemsControl ItemsSource="{Binding SidebarItems}" Margin="0,8">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate x:DataType="vm:SidebarItemViewModel">
                                    <Panel>
                                        <TextBlock Text="{Binding Title}"
                                                   IsVisible="{Binding IsSectionHeader}"
                                                   Padding="12,12,12,4"
                                                   FontSize="11"
                                                   Opacity="0.5"
                                                   FontWeight="SemiBold" />
                                        <Border IsVisible="{Binding !IsSectionHeader}"
                                                Padding="0"
                                                Cursor="Hand"
                                                PointerPressed="OnSidebarItemPressed">
                                            <Border.ContextMenu>
                                                <ContextMenu IsVisible="{Binding IsNavigable}">
                                                    <MenuItem Header="Color">
                                                        <MenuItem Header="Red" Tag="#E81123" Click="OnSidebarSetColorClick" />
                                                        <MenuItem Header="Orange" Tag="#F7630C" Click="OnSidebarSetColorClick" />
                                                        <MenuItem Header="Green" Tag="#107C10" Click="OnSidebarSetColorClick" />
                                                        <MenuItem Header="Blue" Tag="#0078D4" Click="OnSidebarSetColorClick" />
                                                        <MenuItem Header="Purple" Tag="#8764B8" Click="OnSidebarSetColorClick" />
                                                    </MenuItem>
                                                    <MenuItem Header="Clear color" Click="OnSidebarClearColorClick" />
                                                </ContextMenu>
                                            </Border.ContextMenu>
                                            <Grid ColumnDefinitions="3,4,*" MinHeight="36">
                                                <Border Grid.Column="0"
                                                        Background="{DynamicResource HelixSelectionBarBrush}"
                                                        IsVisible="{Binding IsSelected}"
                                                        CornerRadius="0,2,2,0" />
                                                <Border Grid.Column="1"
                                                        Background="{Binding Path, Converter={StaticResource FolderColorConverter}}"
                                                        CornerRadius="2"
                                                        Margin="0,8,0,8" />
                                                <Border Grid.Column="2"
                                                        Padding="8,8"
                                                        Background="{Binding IsSelected, Converter={StaticResource BoolToSidebarBrushConverter}}">
                                                    <TextBlock Text="{Binding Title}" VerticalAlignment="Center" />
                                                </Border>
                                            </Grid>
                                        </Border>
                                    </Panel>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </ScrollViewer>
                </DockPanel>
            </Border>

            <DockPanel Grid.Column="1">
                <Border DockPanel.Dock="Top"
                        IsVisible="{Binding IsDiscoveringNetwork}"
                        Margin="8,8,8,0"
                        Background="{DynamicResource HelixToolbarBrush}"
                        BorderBrush="{DynamicResource HelixBorderColor}"
                        BorderThickness="1"
                        CornerRadius="8"
                        Padding="12,8">
                    <StackPanel Orientation="Horizontal" Spacing="10">
                        <PathIcon Data="M17,3A2,2 0 0,1 19,5V15A2,2 0 0,1 17,17H13V19H14A1,1 0 0,1 15,20H9A1,1 0 0,1 10,19H11V17H7A2,2 0 0,1 5,15V5A2,2 0 0,1 7,3H17M17,5H7V15H17V5Z"
                                  Width="14" Height="14"
                                  Foreground="{DynamicResource HelixAccentBrush}" />
                        <TextBlock Text="{Binding NetworkBannerText}"
                                   VerticalAlignment="Center"
                                   FontSize="12"
                                   Opacity="0.85" />
                    </StackPanel>
                </Border>

                <Border Margin="8"
                        Background="{DynamicResource HelixContentCardBrush}"
                        CornerRadius="{DynamicResource HelixContentCornerRadius}"
                        BorderBrush="{DynamicResource HelixBorderColor}"
                        BorderThickness="1"
                        ClipToBounds="True">
                    <views:DualPaneView DataContext="{Binding SelectedTab}" />
                </Border>
            </DockPanel>
        </Grid>

        <views:CommandPaletteOverlay IsVisible="{Binding IsCommandPaletteOpen}"
                                      IsHitTestVisible="{Binding IsCommandPaletteOpen}"
                                      DataContext="{Binding}" />
    </DockPanel>
</Window>
