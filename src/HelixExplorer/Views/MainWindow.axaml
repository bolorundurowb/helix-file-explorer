<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="using:HelixExplorer.ViewModels"
        x:Class="HelixExplorer.Views.MainWindow"
        x:DataType="vm:MainWindowViewModel"
        Title="{Binding Title}"
        Width="1280" Height="800"
        MinWidth="800" MinHeight="500"
        WindowStartupLocation="CenterScreen"
        ExtendClientAreaToDecorationsHint="True"
        ExtendClientAreaChromeHints="PreferSystemChrome"
        Background="{DynamicResource HelixChromeBrush}">

    <DockPanel LastChildFill="True">

        <!-- Tab Strip -->
        <Border DockPanel.Dock="Top"
                Background="{DynamicResource HelixTabStripBrush}"
                Padding="8,4,8,0"
                Height="40">
            <Grid ColumnDefinitions="*,Auto">
                <StackPanel Grid.Column="0" Orientation="Horizontal" Spacing="2">
                    <!-- Placeholder tab -->
                    <Border CornerRadius="8,8,0,0"
                            Background="{DynamicResource HelixContentCardBrush}"
                            Padding="12,6"
                            MinWidth="160">
                        <StackPanel Orientation="Horizontal" Spacing="8">
                            <PathIcon Data="M4,4H20V20H4V4M6,6V18H18V6H6Z" Width="14" Height="14" />
                            <TextBlock Text="Home" VerticalAlignment="Center" />
                            <Button Content="×" Padding="2" Background="Transparent" BorderThickness="0"
                                    FontSize="14" Opacity="0.6" Cursor="Hand" />
                        </StackPanel>
                    </Border>
                    <!-- New tab button -->
                    <Button Content="+" Padding="8,4" Background="Transparent" BorderThickness="0"
                            FontSize="18" Opacity="0.6" Cursor="Hand" ToolTip.Tip="New Tab (Ctrl+T)" />
                </StackPanel>

                <!-- Dual-pane toggle -->
                <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="4" VerticalAlignment="Center">
                    <Button ToolTip.Tip="Dual Pane (Ctrl+D)" Padding="6" Background="Transparent" BorderThickness="0" Cursor="Hand">
                        <PathIcon Data="M3,3H11V21H3V3M13,3H21V21H13V3M5,5V19H9V5H5M15,5V19H19V5H15Z" Width="16" Height="16" />
                    </Button>
                </StackPanel>
            </Grid>
        </Border>

        <!-- Navigation Row -->
        <Border DockPanel.Dock="Top"
                Background="{DynamicResource HelixToolbarBrush}"
                Padding="8,6">
            <Grid ColumnDefinitions="Auto,*,Auto">
                <!-- Nav buttons -->
                <StackPanel Grid.Column="0" Orientation="Horizontal" Spacing="2">
                    <Button ToolTip.Tip="Back" Padding="6" Background="Transparent" BorderThickness="0" Cursor="Hand">
                        <PathIcon Data="M20,11H7.83L13.42,5.41L12,4L4,12L12,20L13.41,18.59L7.83,13H20V11Z" Width="16" Height="16" />
                    </Button>
                    <Button ToolTip.Tip="Forward" Padding="6" Background="Transparent" BorderThickness="0" Cursor="Hand">
                        <PathIcon Data="M4,11V13H16.17L10.58,18.59L12,20L20,12L12,4L10.59,5.41L16.17,11H4Z" Width="16" Height="16" />
                    </Button>
                    <Button ToolTip.Tip="Up" Padding="6" Background="Transparent" BorderThickness="0" Cursor="Hand">
                        <PathIcon Data="M12,20L13.41,18.59L7.83,13H20V11H7.83L13.42,5.41L12,4L4,12L12,20Z" Width="16" Height="16" />
                    </Button>
                    <Button ToolTip.Tip="Refresh" Padding="6" Background="Transparent" BorderThickness="0" Cursor="Hand">
                        <PathIcon Data="M17.65,6.35C16.2,4.9 14.21,4 12,4A8,8 0 0,0 4,12A8,8 0 0,0 12,20C15.73,20 18.84,17.45 19.73,14H17.65C16.83,16.33 14.61,18 12,18A6,6 0 0,1 6,12A6,6 0 0,1 12,6C13.66,6 15.14,6.69 16.22,7.78L13,11H20V4L17.65,6.35Z" Width="16" Height="16" />
                    </Button>
                </StackPanel>

                <!-- Breadcrumb / Address bar -->
                <Border Grid.Column="1"
                        Margin="8,0"
                        Background="{DynamicResource HelixContentCardBrush}"
                        CornerRadius="4"
                        Padding="8,6"
                        BorderBrush="{DynamicResource HelixBorderColor}"
                        BorderThickness="1">
                    <TextBlock Text="Home" VerticalAlignment="Center" Opacity="0.7" />
                </Border>

                <!-- Search + Settings -->
                <StackPanel Grid.Column="2" Orientation="Horizontal" Spacing="4">
                    <Border Background="{DynamicResource HelixContentCardBrush}"
                            CornerRadius="4"
                            Padding="8,4"
                            BorderBrush="{DynamicResource HelixBorderColor}"
                            BorderThickness="1"
                            MinWidth="200">
                        <StackPanel Orientation="Horizontal" Spacing="6">
                            <PathIcon Data="M9.5,3A6.5,6.5 0 0,1 16,9.5C16,11.11 15.41,12.59 14.44,13.73L14.71,14H15.5L20.5,19L19,20.5L14,15.5V14.71L13.73,14.44C12.59,15.41 11.11,16 9.5,16A6.5,6.5 0 0,1 3,9.5A6.5,6.5 0 0,1 9.5,3M9.5,5C7,5 5,7 5,9.5C5,12 7,14 9.5,14C12,14 14,12 14,9.5C14,7 12,5 9.5,5Z" Width="14" Height="14" Opacity="0.5" />
                            <TextBlock Text="Search" VerticalAlignment="Center" Opacity="0.5" />
                        </StackPanel>
                    </Border>
                    <Button ToolTip.Tip="Settings" Padding="6" Background="Transparent" BorderThickness="0" Cursor="Hand">
                        <PathIcon Data="M12,15.5A3.5,3.5 0 0,1 8.5,12A3.5,3.5 0 0,1 12,8.5A3.5,3.5 0 0,1 15.5,12A3.5,3.5 0 0,1 12,15.5M19.43,12.97C19.47,12.65 19.5,12.33 19.5,12C19.5,11.67 19.47,11.34 19.43,11L21.54,9.37C21.73,9.22 21.78,8.95 21.66,8.73L19.66,5.27C19.54,5.05 19.27,4.96 19.05,5.05L16.56,6.05C16.04,5.66 15.5,5.32 14.87,5.07L14.5,2.42C14.46,2.18 14.25,2 14,2H10C9.75,2 9.54,2.18 9.5,2.42L9.13,5.07C8.5,5.32 7.96,5.66 7.44,6.05L4.95,5.05C4.73,4.96 4.46,5.05 4.34,5.27L2.34,8.73C2.21,8.95 2.27,9.22 2.46,9.37L4.57,11C4.53,11.34 4.5,11.67 4.5,12C4.5,12.33 4.53,12.65 4.57,12.97L2.46,14.63C2.27,14.78 2.21,15.05 2.34,15.27L4.34,18.73C4.46,18.95 4.73,19.04 4.95,18.95L7.44,17.94C7.96,18.34 8.5,18.68 9.13,18.93L9.5,21.58C9.54,21.82 9.75,22 10,22H14C14.25,22 14.46,21.82 14.5,21.58L14.87,18.93C15.5,18.67 16.04,18.34 16.56,17.94L19.05,18.95C19.27,19.04 19.54,18.95 19.66,18.73L21.66,15.27C21.78,15.05 21.73,14.78 21.54,14.63L19.43,12.97Z" Width="16" Height="16" />
                    </Button>
                </StackPanel>
            </Grid>
        </Border>

        <!-- Action Toolbar -->
        <Border DockPanel.Dock="Top"
                Background="{DynamicResource HelixToolbarBrush}"
                Padding="8,4"
                BorderBrush="{DynamicResource HelixBorderColor}"
                BorderThickness="0,0,0,1">
            <Grid ColumnDefinitions="*,Auto">
                <StackPanel Grid.Column="0" Orientation="Horizontal" Spacing="2">
                    <Button ToolTip.Tip="New" Padding="6,4" Background="Transparent" BorderThickness="0" Cursor="Hand">
                        <StackPanel Orientation="Horizontal" Spacing="4">
                            <PathIcon Data="M19,13H13V19H11V13H5V11H11V5H13V11H19V13Z" Width="14" Height="14" />
                            <TextBlock Text="New" VerticalAlignment="Center" FontSize="12" />
                        </StackPanel>
                    </Button>
                    <Border Width="1" Background="{DynamicResource HelixBorderColor}" Margin="4,4" />
                    <Button ToolTip.Tip="Cut (Ctrl+X)" Padding="6" Background="Transparent" BorderThickness="0" Cursor="Hand">
                        <PathIcon Data="M19,3L13,9L15,11L22,4V3M12,12.5A0.5,0.5 0 0,1 11.5,12A0.5,0.5 0 0,1 12,11.5A0.5,0.5 0 0,1 12.5,12A0.5,0.5 0 0,1 12,12.5M6,20A2,2 0 0,1 4,18C4,16.89 4.9,16 6,16A2,2 0 0,1 8,18C8,19.11 7.1,20 6,20M6,8A2,2 0 0,1 4,6C4,4.89 4.9,4 6,4A2,2 0 0,1 8,6C8,7.11 7.1,8 6,8M9.64,7.64C9.87,7.14 10,6.59 10,6A4,4 0 0,0 6,2A4,4 0 0,0 2,6A4,4 0 0,0 6,10C6.59,10 7.14,9.87 7.64,9.64L10,12L7.64,14.36C7.14,14.13 6.59,14 6,14A4,4 0 0,0 2,18A4,4 0 0,0 6,22A4,4 0 0,0 10,18C10,17.41 9.87,16.86 9.64,16.36L12,14L19,21H22V20L9.64,7.64Z" Width="14" Height="14" />
                    </Button>
                    <Button ToolTip.Tip="Copy (Ctrl+C)" Padding="6" Background="Transparent" BorderThickness="0" Cursor="Hand">
                        <PathIcon Data="M19,21H8V7H19M19,5H8A2,2 0 0,0 6,7V21A2,2 0 0,0 8,23H19A2,2 0 0,0 21,21V7A2,2 0 0,0 19,5M16,1H4A2,2 0 0,0 2,3V17H4V3H16V1Z" Width="14" Height="14" />
                    </Button>
                    <Button ToolTip.Tip="Paste (Ctrl+V)" Padding="6" Background="Transparent" BorderThickness="0" Cursor="Hand">
                        <PathIcon Data="M19,20H5V4H7V7H17V4H19M12,2A1,1 0 0,1 13,3A1,1 0 0,1 12,4A1,1 0 0,1 11,3A1,1 0 0,1 12,2M19,2H14.82C14.4,0.84 13.3,0 12,0C10.7,0 9.6,0.84 9.18,2H5A2,2 0 0,0 3,4V20A2,2 0 0,0 5,22H19A2,2 0 0,0 21,20V4A2,2 0 0,0 19,2Z" Width="14" Height="14" />
                    </Button>
                    <Button ToolTip.Tip="Rename (F2)" Padding="6" Background="Transparent" BorderThickness="0" Cursor="Hand">
                        <PathIcon Data="M20.71,7.04C21.1,6.65 21.1,6 20.71,5.63L18.37,3.29C18,2.9 17.35,2.9 16.96,3.29L15.12,5.12L18.87,8.87M3,17.25V21H6.75L17.81,9.93L14.06,6.18L3,17.25Z" Width="14" Height="14" />
                    </Button>
                    <Border Width="1" Background="{DynamicResource HelixBorderColor}" Margin="4,4" />
                    <Button ToolTip.Tip="Share" Padding="6" Background="Transparent" BorderThickness="0" Cursor="Hand">
                        <PathIcon Data="M18,16.08C17.24,16.08 16.56,16.38 16.04,16.85L8.91,12.7C8.96,12.47 9,12.24 9,12C9,11.76 8.96,11.53 8.91,11.3L15.96,7.19C16.5,7.69 17.21,8 18,8A3,3 0 0,0 21,5A3,3 0 0,0 18,2A3,3 0 0,0 15,5C15,5.24 15.04,5.47 15.09,5.7L8.04,9.81C7.5,9.31 6.79,9 6,9A3,3 0 0,0 3,12A3,3 0 0,0 6,15C6.79,15 7.5,14.69 8.04,14.19L15.16,18.34C15.11,18.55 15.08,18.77 15.08,19C15.08,20.61 16.39,21.91 18,21.91C19.61,21.91 20.92,20.61 20.92,19C20.92,17.39 19.61,16.08 18,16.08Z" Width="14" Height="14" />
                    </Button>
                    <Button ToolTip.Tip="Delete" Padding="6" Background="Transparent" BorderThickness="0" Cursor="Hand">
                        <PathIcon Data="M19,4H15.5L14.5,3H9.5L8.5,4H5V6H19M6,19A2,2 0 0,0 8,21H16A2,2 0 0,0 18,19V7H6V19Z" Width="14" Height="14" />
                    </Button>
                    <Button ToolTip.Tip="Properties" Padding="6" Background="Transparent" BorderThickness="0" Cursor="Hand">
                        <PathIcon Data="M11,17H13V11H11V17M12,2A10,10 0 0,0 2,12A10,10 0 0,0 12,22A10,10 0 0,0 22,12A10,10 0 0,0 12,2M12,20A8,8 0 0,1 4,12A8,8 0 0,1 12,4A8,8 0 0,1 20,12A8,8 0 0,1 12,20M11,9H13V7H11V9Z" Width="14" Height="14" />
                    </Button>
                </StackPanel>

                <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="2">
                    <Button ToolTip.Tip="Sort" Padding="6" Background="Transparent" BorderThickness="0" Cursor="Hand">
                        <PathIcon Data="M3,13H15V11H3M3,6V8H21V6M3,18H9V16H3V18Z" Width="14" Height="14" />
                    </Button>
                    <Button ToolTip.Tip="View" Padding="6" Background="Transparent" BorderThickness="0" Cursor="Hand">
                        <PathIcon Data="M3,3H9V9H3V3M3,13H9V19H3V13M13,3H19V9H13V3M13,13H19V19H13V13Z" Width="14" Height="14" />
                    </Button>
                    <Button ToolTip.Tip="More" Padding="6" Background="Transparent" BorderThickness="0" Cursor="Hand">
                        <PathIcon Data="M12,16A2,2 0 0,1 14,18A2,2 0 0,1 12,20A2,2 0 0,1 10,18A2,2 0 0,1 12,16M12,10A2,2 0 0,1 14,12A2,2 0 0,1 12,14A2,2 0 0,1 10,12A2,2 0 0,1 12,10M12,4A2,2 0 0,1 14,6A2,2 0 0,1 12,8A2,2 0 0,1 10,6A2,2 0 0,1 12,4Z" Width="14" Height="14" />
                    </Button>
                </StackPanel>
            </Grid>
        </Border>

        <!-- Status Bar -->
        <Border DockPanel.Dock="Bottom"
                Background="{DynamicResource HelixStatusBarBrush}"
                Padding="12,4"
                BorderBrush="{DynamicResource HelixBorderColor}"
                BorderThickness="0,1,0,0"
                Height="32">
            <Grid ColumnDefinitions="*,Auto">
                <TextBlock Grid.Column="0" Text="{Binding ItemCount, StringFormat='{}{0} items'}"
                           VerticalAlignment="Center" FontSize="12" Opacity="0.7" />
                <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="8">
                    <TextBlock VerticalAlignment="Center" FontSize="12" Opacity="0.7">
                        <TextBlock.Text>
                            <MultiBinding StringFormat="{}{0} selected">
                                <Binding Path="SelectedCount" />
                            </MultiBinding>
                        </TextBlock.Text>
                    </TextBlock>
                </StackPanel>
            </Grid>
        </Border>

        <!-- Main Content: Sidebar + Content Card -->
        <Grid ColumnDefinitions="Auto,*">
            <!-- Sidebar -->
            <Border Grid.Column="0"
                    Background="{DynamicResource HelixSidebarBrush}"
                    Width="{DynamicResource HelixSidebarDefaultWidth}"
                    IsVisible="{Binding IsSidebarOpen}"
                    BorderBrush="{DynamicResource HelixBorderColor}"
                    BorderThickness="0,0,1,0">
                <DockPanel>
                    <!-- Settings at bottom -->
                    <Border DockPanel.Dock="Bottom"
                            Padding="12,8"
                            BorderBrush="{DynamicResource HelixBorderColor}"
                            BorderThickness="0,1,0,0">
                        <StackPanel Orientation="Horizontal" Spacing="10">
                            <PathIcon Data="M12,15.5A3.5,3.5 0 0,1 8.5,12A3.5,3.5 0 0,1 12,8.5A3.5,3.5 0 0,1 15.5,12A3.5,3.5 0 0,1 12,15.5M19.43,12.97C19.47,12.65 19.5,12.33 19.5,12C19.5,11.67 19.47,11.34 19.43,11L21.54,9.37C21.73,9.22 21.78,8.95 21.66,8.73L19.66,5.27C19.54,5.05 19.27,4.96 19.05,5.05L16.56,6.05C16.04,5.66 15.5,5.32 14.87,5.07L14.5,2.42C14.46,2.18 14.25,2 14,2H10C9.75,2 9.54,2.18 9.5,2.42L9.13,5.07C8.5,5.32 7.96,5.66 7.44,6.05L4.95,5.05C4.73,4.96 4.46,5.05 4.34,5.27L2.34,8.73C2.21,8.95 2.27,9.22 2.46,9.37L4.57,11C4.53,11.34 4.5,11.67 4.5,12C4.5,12.33 4.53,12.65 4.57,12.97L2.46,14.63C2.27,14.78 2.21,15.05 2.34,15.27L4.34,18.73C4.46,18.95 4.73,19.04 4.95,18.95L7.44,17.94C7.96,18.34 8.5,18.68 9.13,18.93L9.5,21.58C9.54,21.82 9.75,22 10,22H14C14.25,22 14.46,21.82 14.5,21.58L14.87,18.93C15.5,18.67 16.04,18.34 16.56,17.94L19.05,18.95C19.27,19.04 19.54,18.95 19.66,18.73L21.66,15.27C21.78,15.05 21.73,14.78 21.54,14.63L19.43,12.97Z" Width="16" Height="16" />
                            <TextBlock Text="Settings" VerticalAlignment="Center" />
                        </StackPanel>
                    </Border>

                    <!-- Sidebar entries -->
                    <ScrollViewer VerticalScrollBarVisibility="Auto">
                        <StackPanel Margin="0,8">
                            <!-- Home -->
                            <Border Padding="12,8" Cursor="Hand" Background="Transparent">
                                <StackPanel Orientation="Horizontal" Spacing="10">
                                    <PathIcon Data="M10,20V14H14V20H19V12H22L12,3L2,12H5V20H10Z" Width="16" Height="16" />
                                    <TextBlock Text="Home" VerticalAlignment="Center" />
                                </StackPanel>
                            </Border>

                            <!-- Pinned section header -->
                            <TextBlock Text="Pinned" Padding="12,12,12,4" FontSize="11" Opacity="0.5" FontWeight="SemiBold" />
                            <Border Padding="12,8" Cursor="Hand" Background="Transparent">
                                <StackPanel Orientation="Horizontal" Spacing="10">
                                    <PathIcon Data="M19,17H22V19H19V17M2,17H5V19H2V17M6,17H9V19H6V17M10,17H13V19H10V17M14,17H17V19H14V17M19,13H22V15H19V13M2,13H5V15H2V13M6,13H9V15H6V13M10,13H13V15H10V13M14,13H17V15H14V13M2,9H22V11H2V9Z" Width="16" Height="16" />
                                    <TextBlock Text="Desktop" VerticalAlignment="Center" />
                                </StackPanel>
                            </Border>
                            <Border Padding="12,8" Cursor="Hand" Background="Transparent">
                                <StackPanel Orientation="Horizontal" Spacing="10">
                                    <PathIcon Data="M5,20V8H19V20H5M3,4V6H7V4H3M9,4V6H15V4H9M17,4V6H21V4H17M3,8H21V22H3V8Z" Width="16" Height="16" />
                                    <TextBlock Text="Downloads" VerticalAlignment="Center" />
                                </StackPanel>
                            </Border>
                            <Border Padding="12,8" Cursor="Hand" Background="Transparent">
                                <StackPanel Orientation="Horizontal" Spacing="10">
                                    <PathIcon Data="M14,2H6A2,2 0 0,0 4,4V20A2,2 0 0,0 6,22H18A2,2 0 0,0 20,20V8L14,2M18,20H6V4H13V9H18V20Z" Width="16" Height="16" />
                                    <TextBlock Text="Documents" VerticalAlignment="Center" />
                                </StackPanel>
                            </Border>
                            <Border Padding="12,8" Cursor="Hand" Background="Transparent">
                                <StackPanel Orientation="Horizontal" Spacing="10">
                                    <PathIcon Data="M12,3V12.26C11.5,12.09 11,12 10.5,12C8,12 6,14 6,16.5C6,19 8,21 10.5,21C13,21 15,19 15,16.5V6H19V3H12Z" Width="16" Height="16" />
                                    <TextBlock Text="Music" VerticalAlignment="Center" />
                                </StackPanel>
                            </Border>
                            <Border Padding="12,8" Cursor="Hand" Background="Transparent">
                                <StackPanel Orientation="Horizontal" Spacing="10">
                                    <PathIcon Data="M19,4H15.5L14.5,3H9.5L8.5,4H5V6H19M6,19A2,2 0 0,0 8,21H16A2,2 0 0,0 18,19V7H6V19Z" Width="16" Height="16" />
                                    <TextBlock Text="Recycle Bin" VerticalAlignment="Center" />
                                </StackPanel>
                            </Border>

                            <!-- Drives section header -->
                            <TextBlock Text="Drives" Padding="12,12,12,4" FontSize="11" Opacity="0.5" FontWeight="SemiBold" />
                            <Border Padding="12,8" Cursor="Hand" Background="Transparent">
                                <StackPanel Orientation="Horizontal" Spacing="10">
                                    <PathIcon Data="M5,14H19V16H5V14M5,10H19V12H5V10M5,6H19V8H5V6Z" Width="16" Height="16" />
                                    <TextBlock Text="This PC" VerticalAlignment="Center" />
                                </StackPanel>
                            </Border>

                            <!-- Network section header -->
                            <TextBlock Text="Network" Padding="12,12,12,4" FontSize="11" Opacity="0.5" FontWeight="SemiBold" />
                            <Border Padding="12,8" Cursor="Hand" Background="Transparent">
                                <StackPanel Orientation="Horizontal" Spacing="10">
                                    <PathIcon Data="M1,11L5,15L9,11H6V7H11V10L15,6L11,2V5H4A2,2 0 0,0 2,7V11H1M23,11L19,7L15,11H18V15H13V12L9,16L13,20V17H20A2,2 0 0,0 22,15V11H23Z" Width="16" Height="16" />
                                    <TextBlock Text="Network" VerticalAlignment="Center" />
                                </StackPanel>
                            </Border>

                            <!-- Cloud section (stub) -->
                            <TextBlock Text="Cloud" Padding="12,12,12,4" FontSize="11" Opacity="0.3" FontWeight="SemiBold" />

                            <!-- Tags section (stub) -->
                            <TextBlock Text="Tags" Padding="12,12,12,4" FontSize="11" Opacity="0.3" FontWeight="SemiBold" />
                        </StackPanel>
                    </ScrollViewer>
                </DockPanel>
            </Border>

            <!-- Content Card -->
            <Border Grid.Column="1"
                    Margin="8"
                    Background="{DynamicResource HelixContentCardBrush}"
                    CornerRadius="{DynamicResource HelixContentCornerRadius}"
                    BorderBrush="{DynamicResource HelixBorderColor}"
                    BorderThickness="1">
                <Grid>
                    <TextBlock Text="Content Area"
                               HorizontalAlignment="Center"
                               VerticalAlignment="Center"
                               Opacity="0.3"
                               FontSize="16" />
                </Grid>
            </Border>
        </Grid>
    </DockPanel>
</Window>
