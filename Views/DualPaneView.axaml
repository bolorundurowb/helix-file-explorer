<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:HelixExplorer.ViewModels"
             xmlns:views="using:HelixExplorer.Views"
             x:Class="HelixExplorer.Views.DualPaneView"
             x:Name="Root"
             x:CompileBindings="False">
    <!-- Row/column layout is configured in code-behind so the split can flip between
         horizontal and vertical, and collapse to a single pane. -->
    <Grid x:Name="LayoutGrid">
        <Border x:Name="LeftHost"
                BorderBrush="{DynamicResource HelixAccentBrush}"
                BorderThickness="{Binding Left.IsActive, Converter={StaticResource BoolToThicknessConverter}}"
                PointerPressed="OnLeftPressed">
            <views:PaneView DataContext="{Binding Left}" />
        </Border>

        <GridSplitter x:Name="Splitter"
                      Background="{DynamicResource HelixAccentBrush}"
                      IsVisible="{Binding IsDualPane}" />

        <Border x:Name="RightHost"
                BorderBrush="{DynamicResource HelixAccentBrush}"
                BorderThickness="{Binding Right.IsActive, Converter={StaticResource BoolToThicknessConverter}}"
                IsVisible="{Binding IsDualPane}"
                PointerPressed="OnRightPressed">
            <views:PaneView DataContext="{Binding Right}" />
        </Border>
    </Grid>
</UserControl>
