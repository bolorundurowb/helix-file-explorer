<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:HelixExplorer.ViewModels"
             xmlns:models="using:HelixExplorer.Models"
             xmlns:controls="using:HelixExplorer.Controls"
             x:Class="HelixExplorer.Views.PaneView"
             x:CompileBindings="False">

    <Grid x:Name="PaneRoot"
          RowDefinitions="Auto,*,Auto"
          Background="{DynamicResource HelixPaneBackgroundBrush}"
          DragDrop.AllowDrop="True"
          DragDrop.DragOver="OnDragOver"
          DragDrop.Drop="OnDrop"
          KeyDown="OnPaneKeyDown">
        <!-- Toolbar -->
        <Border Grid.Row="0" Background="{DynamicResource HelixSurfaceBrush}" Padding="4">
            <StackPanel Orientation="Horizontal" Spacing="4">
                <Button ToolTip.Tip="Back" Command="{Binding GoBackCommand}" Padding="6,2" FontSize="12">← Back</Button>
                <Button ToolTip.Tip="Forward" Command="{Binding GoForwardCommand}" Padding="6,2" FontSize="12">→ Forward</Button>
                <Button ToolTip.Tip="Up to parent" Command="{Binding GoUpCommand}" Padding="6,2" FontSize="12">↑ Up</Button>
                <Button ToolTip.Tip="Refresh" Command="{Binding RefreshCommand}" Padding="6,2" FontSize="14">🔄</Button>
                <Button ToolTip.Tip="Copy path" Command="{Binding CopyPathCommand}" Padding="6,2" FontSize="14">📋</Button>
                <Button ToolTip.Tip="Open in other pane" Command="{Binding OpenInOtherPaneCommand}" CommandParameter="{Binding SelectedEntry}" Padding="6,2" FontSize="12">⧉ Other pane</Button>
                <TextBox x:Name="FilterBox" Text="{Binding FilterText, Mode=TwoWay}" Watermark="🔍 Filter (Ctrl+F)…" Width="160" VerticalAlignment="Center" />
                <ComboBox x:Name="ViewModeSelector"
                          SelectedIndex="0"
                          SelectionChanged="OnViewModeSelectionChanged"
                          MinWidth="100"
                          VerticalAlignment="Center">
                    <x:String>Details</x:String>
                    <x:String>Grid</x:String>
                    <x:String>Miller</x:String>
                </ComboBox>
            </StackPanel>
        </Border>

        <!-- Details view (built-in column sorting shows chevron indicators). -->
        <DataGrid x:Name="DetailsGrid"
                  Grid.Row="1"
                  ItemsSource="{Binding FilteredEntries}"
                  AutoGenerateColumns="False"
                  IsReadOnly="True"
                  CanUserSortColumns="True"
                  CanUserResizeColumns="True"
                  SelectionMode="Single"
                  GridLinesVisibility="Horizontal"
                  HeadersVisibility="Column"
                  DoubleTapped="OnItemActivated"
                  SelectionChanged="OnDetailsSelectionChanged"
                  ContextFlyout="{x:Null}">
            <DataGrid.Columns>
                <DataGridTextColumn Header="Name" Binding="{Binding Name}" SortMemberPath="Name" Width="2*" />
                <DataGridTextColumn Header="Size" Binding="{Binding Size, Converter={StaticResource FileSizeConverter}}" SortMemberPath="Size" Width="90" />
                <DataGridTextColumn Header="Modified" Binding="{Binding Modified, StringFormat={}{0:g}}" SortMemberPath="Modified" Width="160" />
                <DataGridTextColumn Header="Type" Binding="{Binding Extension}" SortMemberPath="Extension" Width="80" />
            </DataGrid.Columns>
        </DataGrid>

        <!-- Grid / icon view. Ctrl+wheel scales thumbnails (32–256). -->
        <ScrollViewer x:Name="GridScroll"
                      Grid.Row="1"
                      IsVisible="False"
                      PointerWheelChanged="OnGridWheel"
                      HorizontalScrollBarVisibility="Disabled"
                      VerticalScrollBarVisibility="Auto">
            <ItemsControl ItemsSource="{Binding FilteredEntries}">
                <ItemsControl.ItemsPanel>
                    <ItemsPanelTemplate>
                        <WrapPanel Orientation="Horizontal" />
                    </ItemsPanelTemplate>
                </ItemsControl.ItemsPanel>
                <ItemsControl.ItemTemplate>
                    <DataTemplate DataType="models:FileSystemEntry">
                        <Border Width="{Binding $parent[UserControl].DataContext.ThumbnailSize}"
                                Margin="4" Padding="4"
                                CornerRadius="6"
                                BorderBrush="{DynamicResource HelixAccentBrush}" BorderThickness="1"
                                Background="{Binding FullPath, Converter={StaticResource FolderColorConverter}}"
                                PointerPressed="OnTilePointerPressed"
                                PointerMoved="OnTilePointerMoved"
                                DoubleTapped="OnTileDoubleTapped">
                            <Border.ContextFlyout>
                                <MenuFlyout>
                                    <MenuItem Header="⧉ Open in other pane"
                                              Command="{Binding $parent[UserControl].DataContext.OpenInOtherPaneCommand}"
                                              CommandParameter="{Binding}" />
                                    <MenuItem Header="🎨 Set folder colour…" Click="OnSetFolderColor" />
                                    <MenuItem Header="📋 Copy current path"
                                              Command="{Binding $parent[UserControl].DataContext.CopyPathCommand}" />
                                </MenuFlyout>
                            </Border.ContextFlyout>
                            <StackPanel Spacing="4" HorizontalAlignment="Center">
                                <TextBlock Text="{Binding Icon}"
                                           FontSize="{Binding $parent[UserControl].DataContext.ThumbnailSize, Converter={StaticResource ScaleConverter}, ConverterParameter=0.5}"
                                           HorizontalAlignment="Center" />
                                <TextBlock Text="{Binding Name}" HorizontalAlignment="Center"
                                           TextTrimming="CharacterEllipsis"
                                           MaxWidth="{Binding $parent[UserControl].DataContext.ThumbnailSize, Converter={StaticResource ScaleConverter}, ConverterParameter=0.92}" />
                                <TextBlock Text="{Binding Size, Converter={StaticResource FileSizeConverter}}" FontSize="10"
                                           Opacity="0.7" HorizontalAlignment="Center" />
                            </StackPanel>
                        </Border>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>
        </ScrollViewer>

        <!-- Miller columns view -->
        <ScrollViewer x:Name="MillerScroll"
                      Grid.Row="1"
                      IsVisible="False"
                      HorizontalScrollBarVisibility="Auto"
                      VerticalScrollBarVisibility="Disabled">
            <controls:MillerColumnPanel x:Name="MillerPanel" ColumnActivated="OnMillerColumnActivated" />
        </ScrollViewer>

        <!-- Footer: status + thumbnail size slider -->
        <Grid Grid.Row="2" ColumnDefinitions="*,Auto" Margin="4,2">
            <TextBlock Grid.Column="0" Text="{Binding StatusText}" Opacity="0.7" VerticalAlignment="Center" />
            <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="4" VerticalAlignment="Center">
                <TextBlock Text="🖼" VerticalAlignment="Center" FontSize="12" />
                <Slider Minimum="32" Maximum="256" Width="120"
                        Value="{Binding ThumbnailSize, Mode=TwoWay}"
                        ToolTip.Tip="Thumbnail size" />
            </StackPanel>
        </Grid>
    </Grid>

    <UserControl.ContextFlyout>
        <MenuFlyout>
            <MenuItem Header="🖥️ Open in Terminal" Click="OnOpenInTerminal" />
            <MenuItem Header="📋 Copy Path" Command="{Binding CopyPathCommand}" />
            <MenuItem Header="⧉ Open in Other Pane" Command="{Binding OpenInOtherPaneCommand}" CommandParameter="{Binding SelectedEntry}" />
            <MenuItem Header="📑 Show Native Context Menu" Click="OnShowNativeContextMenu" />
        </MenuFlyout>
    </UserControl.ContextFlyout>
</UserControl>
