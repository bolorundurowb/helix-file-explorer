<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:HelixExplorer.ViewModels"
             x:Class="HelixExplorer.Views.Omnibar"
             x:DataType="vm:PaneViewModel">
    <Grid>
        <StackPanel IsVisible="{Binding IsHomeMode}"
                    Orientation="Horizontal"
                    Spacing="8"
                    VerticalAlignment="Center"
                    Margin="4,0">
            <PathIcon Data="M10,20V14H14V20H19V12H22L12,3L2,12H5V20H10Z"
                      Width="16" Height="16"
                      Foreground="{DynamicResource HelixAccentBrush}" />
            <TextBlock Text="Home"
                       FontSize="14"
                       VerticalAlignment="Center" />
        </StackPanel>

        <Grid IsVisible="{Binding IsSearchMode}" ColumnDefinitions="Auto,*">
            <PathIcon Grid.Column="0"
                      Data="M9.5,3A6.5,6.5 0 0,1 16,9.5C16,11.11 15.41,12.59 14.44,13.73L14.71,14H15.5L20.5,19L19,20.5L14,15.5V14.71L13.73,14.44C12.59,15.41 11.11,16 9.5,16A6.5,6.5 0 0,1 3,9.5A6.5,6.5 0 0,1 9.5,3M9.5,5C7,5 5,7 5,9.5C5,12 7,14 9.5,14C12,14 14,12 14,9.5C14,7 12,5 9.5,5Z"
                      Width="16" Height="16"
                      Margin="4,0,8,0"
                      VerticalAlignment="Center"
                      Opacity="0.6" />
            <TextBox Grid.Column="1"
                     Text="{Binding FilterText, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                     PlaceholderText="Search current folder"
                     BorderThickness="0"
                     Background="Transparent"
                     Padding="0"
                     KeyDown="OnSearchBoxKeyDown"
                     LostFocus="OnSearchBoxLostFocus" />
        </Grid>

        <Grid IsVisible="{Binding IsPathMode}">
            <ScrollViewer x:Name="BreadcrumbScroll"
                          IsVisible="{Binding !IsEditingPath}"
                          Background="Transparent"
                          PointerPressed="OnBreadcrumbAreaPressed"
                          HorizontalScrollBarVisibility="Auto"
                          VerticalScrollBarVisibility="Disabled">
                <StackPanel x:Name="BreadcrumbHost" Orientation="Horizontal" Spacing="0" />
            </ScrollViewer>

            <TextBox x:Name="PathBox"
                     IsVisible="{Binding IsEditingPath}"
                     Text="{Binding EditablePath}"
                     KeyDown="OnPathBoxKeyDown"
                     LostFocus="OnPathBoxLostFocus"
                     PlaceholderText="Type a path and press Enter…" />
        </Grid>
    </Grid>
</UserControl>
